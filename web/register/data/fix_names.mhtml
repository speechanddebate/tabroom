<%args>
	$tourn
	$dbh
	$perms
	$tourn_settings
	$person
	$whoami => undef
</%args>
<%init>

	my $judge_sth = $dbh->prepare("
		select
			judge.id, judge.first, judge.last, judge.middle
				from judge, category
			where 1=1
				and category.tourn = ?
				and category.id = judge.category
	");

	my $student_sth = $dbh->prepare("
		select
			student.id, student.first, student.last, student.middle
				from student, entry_student es, entry, event
			where 1=1
				and event.tourn = ?
				and event.id = entry.event
				and entry.id = es.entry
				and es.student = student.id
	");

	$judge_sth->execute($tourn->id);
	$student_sth->execute($tourn->id);

	my $judges = $judge_sth->fetchall_hash();
	my $students = $student_sth->fetchall_hash();

	my $uj_sth = $dbh->prepare("
		update judge
			set first = ?, last = ?, middle = ?,
			timestamp = timestamp
			where id = ?
	");

	my $us_sth = $dbh->prepare("
		update student
			set first = ?, last = ?, middle = ?,
			timestamp = timestamp
			where id = ?
	");

	my @tags = ("first", "last", "middle");
	my $msg;
	my $delta = 0;

	foreach my $judge (@{$judges}) {

		my @names;

		foreach my $tag (@tags) {

			my $punctuate = $judge->{$tag};
			$punctuate =~ s/[\W_]//g;

			if (
				length($judge->{$tag}) == length($punctuate)
				&& ($judge->{$tag} eq lc($judge->{$tag})
				|| $judge->{$tag} eq uc($judge->{$tag}))
			) {
				$judge->{$tag} = ucfirst(lc($judge->{$tag}));
				$delta++;
			}
			push @names, $judge->{$tag};
		}

		if ($delta) {
			push @names, $judge->{id};
			$uj_sth->execute(@names);
		}
	}

	$msg .= " $delta judge names corrected. ";
	$delta = 0;

	foreach my $student (@{$students}) {

		my @names;

		foreach my $tag (@tags) {

			my $punctuate = $student->{$tag};
			$punctuate =~ s/[\W_]//g;

			if (
				length($student->{$tag}) > length($punctuate)
				&& ($student->{$tag} eq lc($student->{$tag})
				|| $student->{$tag} eq uc($student->{$tag}))
			) {
				$student->{$tag} = ucfirst(lc($student->{$tag}));
				$delta++;
			}
			push @names, $student->{$tag};
		}

		if ($delta) {
			push @names, $student->{id};
			$us_sth->execute(@names);
		}
	}

	$msg .= " $delta student names corrected. ";

	$m->redirect("index.mhtml?msg=$msg");

</%init>
