<%args>
	$tourn
	$dbh
	$now
	$tourn_settings
	$award => "ward"
	$person
</%args>
<%init>

	my $limit;

	if ($award eq "ward") {
		$limit = "and exists ( select entry.id from entry, event where school.id = entry.school and entry.event = event.id and event.type = 'congress' )";
	}

	my $stored_sth = $dbh->prepare("
		select
			school.id, school.name school_name,
			school.chapter,
			award.id award, award.value points, award.timestamp,
			region.id region_id, region.name region_name

		from school

			left join chapter_setting award
				on award.chapter = school.chapter
				and award.tag = ?

			left join region on school.region = region.id

		where 1=1
			and school.tourn = ?
			$limit
		order by school.name
	");

	$stored_sth->execute($award, $tourn->id);
	my $stores = $stored_sth->fetchall_hash();

	my $create_sth = $dbh->prepare("insert into chapter_setting ( value, chapter, tag) values (?, ?, ?) ");
	my $update_sth = $dbh->prepare("update chapter_setting set value = ? where chapter = ? and tag = ?");

	my $nowstamp = DateTime::Format::MySQL->format_datetime($now);

	if ($ARGS{saveme}) {
		foreach my $store (@{$stores}) {
			if ($store->{points} ne $ARGS{$store->{chapter}}) {
				if ($store->{award}) {
					$update_sth->execute($ARGS{$store->{chapter}}, $store->{chapter}, $award);
				} else {
					$create_sth->execute($ARGS{$store->{chapter}}, $store->{chapter}, $award);
				}

				$stores->{points}    = $ARGS{$stores->{chapter}};
				$stores->{timestamp} = $nowstamp;
			}
		}
	}

</%init>

	<&
		"menu.mas",
		tourn          => $tourn,
		tourn_settings => $tourn_settings,
		whoami         => "ncfl_cumulative",
		person         => $person
	&>

	<div class="main">

		<div class='flexrow'>
			<span class="twothirds">
				<h4><% ucfirst($award) %> Trophy</h4>
			</span>
			<span class="third rightalign" id="<% $award %>_buttonarea">
			</span>
		</div>

		<& "/funclib/tablesorter.mas", table => $award &>

		<form action="cumulative.mhtml" method="post">

		<input
			type  = "hidden"
			name  = "saveme"
			value = 1
		>

		<table id="<% $award %>">

			<thead>
				<tr>
					<th>
						School
					</th>

%					if ($tourn_settings->{ncfl}) {
						<th>
							Diocese
						</th>
%					}

					<th>
						Accumulated Points
					</th>

					<th>
						Last Update
					</th>
				</tr>
			</thead>

			<tbody>
%				foreach my $store (@{$stores}) {
					<tr>
						<td>
							<% $store->{school_name} %>
						</td>

%						if ($tourn_settings->{ncfl}) {
							<td>
								<% $store->{region_name} %>
							</td>
%						}

						<td class="centeralign"
							data-text="<% $store->{points} %>"
						>
							<input
								name  = <% $store->{chapter} %>
								type  = "number"
								value = "<% $store->{points} %>"
							>
						</td>

						<td class="centeralign">
							<% $store->{timestamp} %>
						</td>
					</tr>
%				}
			</tbody>
		<table>

		<div class='libl rightalign flexrow'>
			<span class="third centeralign">
				<input type="submit" value="Save Points">
			</span>
		</div>

	</div>
