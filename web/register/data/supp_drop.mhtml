<%args>
	$dbh
	$tourn
	$tourn_settings
</%args>
<%init>

	if ($ARGS{"activate"}) {

		my $sth = $dbh->prepare("
			update
				entry, entry_student eso, event
			set entry.dropped = 0
			where entry.active = 0
				and entry.unconfirmed = 0
				and entry.id = eso.entry
				and entry.event = event.id
				and event.tourn = ?

				and not exists (
					select es.id
						from entry_student es, entry other, event other_event
					where es.student = eso.student
						and es.entry = other.id
						and other.event = other_event.id
						and other_event.tourn = event.tourn
						and not exists (
							select evs.id
								from event_setting evs
							where evs.event = other_event.id
								and evs.tag = 'supp'
						)
				)
		");

		$sth->execute($tourn->id);
		my $message = "Activated all supp only entries for re-registration";
		$m->redirect("index.mhtml?msg=$message");

	} elsif ($ARGS{all})  {

		my $sth = $dbh->prepare("
			update
				entry, event, event_setting supp, entry_student es, student

			set entry.dropped = 1

			where 1=1

				and supp.tag = 'supp'
				and supp.event = entry.event
				and supp.event = event.id
				and event.tourn = ?

				and entry.active = 1
				and entry.id = es.entry
				and es.student = student.id
		");

		$sth->execute($tourn->id);
		my $message = "Deactivated all supp entries ";
		$m->redirect("index.mhtml?msg=$message");

	} else {

		my $sth = $dbh->prepare("
			update
				entry, event, event_setting supp, entry_student es, student

			set entry.dropped = 1

			where 1=1

				and supp.tag = 'supp'
				and supp.event = entry.event
				and supp.event = event.id
				and event.tourn = ?

				and entry.active = 1
				and entry.id = es.entry
				and es.student = student.id

				and EXISTS (
					select e2.id
					from entry e2, entry_student es2, event ev2
					where 1=1

					and es2.student = student.id
					and es2.entry   = e2.id
					and e2.event    = ev2.id
					and ev2.tourn   = event.tourn

					AND NOT EXISTS (
						select es2.id
						from event_setting es2
						where es2.event = ev2.id
						and es2.tag = 'supp'
					)
				)
		");

		$sth->execute($tourn->id);
		my $message = "Deactivated all supp entries who have a main event for re-registration";
		$m->redirect("index.mhtml?msg=$message");
	}


</%init>

