<%args>
	$tourn
	$tourn_settings
	$return => undef
</%args>
<%init>

	unless ($ARGS{'return'}) {
		$m->clear_buffer();
		$r->content_type('application/json');
	}

	Tab::School->columns(TEMP => 'njw');

	Tab::School->set_sql( actually_exists => "
		select
			school.*,
			(select njw.value
				from school_setting njw
				where njw.school = school.id
				and njw.tag = 'no_judge_warnings'
			) as njw
		from school
		where 1=1
			and school.tourn = ?
			and (
				EXISTS ( select entry.id from entry where entry.school = school.id )
				OR EXISTS ( select judge.id from judge where judge.school = school.id )
				OR EXISTS ( select fine.id from fine where fine.school = school.id )
			)
		order by school.name
	");

	my @schools = Tab::School->search_actually_exists($tourn->id);
	my %reasons;
	my %school_reasons;
	my $last;

	foreach my $school (@schools) {

		my %args = $m->comp("/funclib/judgemath/nats_check_judging.mas",
			school         => $school,
			tourn          => $tourn,
			tourn_settings => $tourn_settings
		);

		foreach my $key (keys (%{$args{scoreboard}})) {
			$reasons{problems}{$key} += $args{scoreboard}{$key};
			$reasons{problems_schoolcount}{$key}++;
		}
	}

	$reasons{school_total} = scalar @schools;

	return \%reasons if $ARGS{'return'};

	$m->print('{
		"error": false,
		"message": "Judging check complete"
	}');

	$m->abort();

</%init>
