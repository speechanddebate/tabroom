<%args>
	$judge_id => undef
	$dbh
</%args>
<%init>

	my $msg;

	my $sth = $dbh->prepare("
		update judge set person = NULL where id = ?
	");

	my $cj_sth = $dbh->prepare("
		update chapter_judge set person = NULL, email = NULL, phone = NULL where id = ?
	");

	if ($judge_id) {

		my $judge = Tab::Judge->retrieve($judge_id);

		if ($judge) {

			my $person = $judge->person;
			$sth->execute($judge->id);

			my $cj = $judge->chapter_judge;

			if ($cj && $cj->person == $person) {
				$cj_sth->execute($judge->id);
			}

			$msg = "Judge ".$judge->last." unlinked from ".$person->email;
		} else {

			$msg = "No judge found with ID $judge_id";
		}
	}

	$m->redirect("edit.mhtml?judge_id=".$judge_id."&msg=$msg");

</%init>
