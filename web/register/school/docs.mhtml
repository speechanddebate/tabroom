<%args>
	$dbh
	$now
	$school_id
	$tourn
	$tourn_settings
	$person
	$person_settings
</%args>
<%init>

	my $school = eval { return Tab::School->retrieve($school_id); };
	unless ($school) { $m->redirect("/register/index.mhtml"); }
	my $chapter = $school->chapter();

	my $tz = $tourn->tz;
	$tz = "UTC" unless $tz;

	my @changes =  Tab::ChangeLog->search(
		school => $school->id
	);

	my $student_sth = $dbh->prepare("
		select
			student.id, student.first, student.last, student.nsda, student.person
		from student, entry_student es, entry
		where 1=1
			and entry.active = 1
			and entry.school = ?
			and entry.id     = es.entry
			and es.student   = student.id
		group by student.id
		order by student.last, student.first
	");

	$student_sth->execute($school->id);
	my $students = $student_sth->fetchall_hash();

	my %release_forms = eval {
		return %{JSON::decode_json($school->setting("release_forms"))};
	};

	my %eligibility_forms = eval {
		return %{JSON::decode_json($school->setting("eligibility_forms"))};
	};

</%init>

	<&
		"/register/menubar.mas",
		school         => $school,
		whoami         => "docs",
		tourn          => $tourn,
		tourn_settings => $tourn_settings
	&>

	<div class="full flexrow martopmore">
		<span class="fourfifths">
			<h4 class="nospace">Individual Uploads</h4>
		</span>

		<span
			class="fifth rightalign bigger semibold"
			id    = "docs_buttonarea"
		> </span>
	</div>

	<& /funclib/tablesorter.mas, table => "docs" &>

	<table id="docs">

		<thead>
			<tr class="yellowrow">
				<th class="smaller">
					First
				</th>
				<th class="smaller">
					Last
				</th>

				<th class="smaller">
					Link?
				</th>

				<th class="smaller">
					NSDA?
				</th>

%				if ($tourn_settings->{entry_release}) {
					<th class="smaller">
						Release
					</th>
%				}

%				if ($tourn_settings->{entry_upload}) {
					<th class="smaller">
						Eligibility
					</th>
%				}

			</tr>
		</thead>

		<tbody>

%			foreach my $student (@{$students}) {

				<tr id="<% $student->{id} %>">

					<td class="smallish">
						<a
							href  = "/register/entry/student_edit.mhtml?student_id=<% $student->{id} %>"
							class = "full plain"
						><% $student->{first} %></a>
					</td>

					<td class="smallish">
						<a
							href  = "/register/entry/student_edit.mhtml?student_id=<% $student->{id} %>"
							class = "full plain"
						><% $student->{last} %></a>
					</td>

					<td class="smallish centeralign <% $student->{person} ? "greentext" : "redtext" %>">
						<% $student->{person} ? "Y" : "N" %>
					</td>

					<td class="smallish centeralign <% $student->{nsda} ? "greentext" : "redtext" %>">
						<% $student->{nsda} ? "Y" : "N" %>
					</td>

%					if ($tourn_settings->{entry_release}) {
						<td
							class     = "centeralign"
							data-text = "<% $release_forms{$student->{id}} ? "Y" : "N" %>"
						>
%							if ($release_forms{$student->{id}}) {
								<a
									class = "buttonwhite fa fa-file-o bluetext"
									title = "<% $release_forms{$student->{id}} %>"
									href  = "<% $Tab::s3_url %>/<% $tourn->id."/release/".$school->id."/".$student->{id}."/".$release_forms{$student->{id}} %>"
								></a>
%							} else {
								X
%							}
						</td>
%					}

%					if ($tourn_settings->{entry_upload}) {
						<td
							class     = "centeralign"
							data-text = "<% $eligibility_forms{$student->{id}} ? "Y" : "N" %>"
						>
%							if ($eligibility_forms{$student->{id}}) {
								<a
									class = "buttonwhite fa fa-file-o bluetext"
									title = "<% $eligibility_forms{$student->{id}} %>"
									href  = "<% $Tab::s3_url %>/<% $tourn->id."/eligibility/".$school->id."/".$student->{id}."/".$eligibility_forms{$student->{id}} %>"
								></a>
%							} else {
								X
%							}
						</td>
%					}
				</tr>
%			}
		</tbody>
	</table>


