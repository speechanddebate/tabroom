<%args>
    $person
    $school        => undef
    $school_id     => undef
    $admin         => undef
	$property_name => undef
</%args>
<%init>

    $school = Tab::School->retrieve($school_id) unless $school;

	unless ($admin) {
		$admin = 0;
	}

	my $debug;
	if ($r->hostname ne "www.tabroom.com") {
		$debug++;
	}

    my $msg = $m->comp( "/funclib/nsda/create_invoice.mas",
        person        => $person,
        school        => $school,
		property_name => $property_name,
		debug         => $debug,
		admin         => $admin
    );

	if ($msg) {
		$m->clear_buffer();
		$r->content_type('application/json');
		$m->print('{ "error": false, "message": "'.$msg.'"}');
	}

	$m->abort();

</%init>
