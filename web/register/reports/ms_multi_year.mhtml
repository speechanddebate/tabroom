<%args>
	$person
	$dbh
	$tourn
	$tourn_settings
</%args>
<%init>

	my $sth = $dbh->prepare("
		select
			student.id, student.first, student.last, student.nsda,
			chapter.name, chapter.formal, chapter.state, chapter.nsda chapter_nsda,
			GROUP_CONCAT(event.abbr) events,
			(select COUNT(DISTINCT ev2.tourn)
				from entry e2, entry_student es2, event ev2, tourn_setting nsda_ms_nats
				where es2.student = student.id
					and es2.entry = e2.id
					and e2.event = ev2.id
					and ev2.tourn = nsda_ms_nats.tourn
					and nsda_ms_nats.tag = 'nsda_ms_nats'
					and ev2.tourn != event.tourn
			) years

		from (student, entry_student es, entry, event)

			left join chapter on student.chapter = chapter.id

		where 1=1
			and event.tourn = ?
			and event.id    = entry.event
			and entry.id    = es.entry
			and es.student  = student.id

		GROUP BY student.id
		ORDER BY years DESC, student.last, student.first
	");

	$sth->execute($tourn->id);
	my $years = $sth->fetchall_hash();

	my %counts;

</%init>

	<& "/funclib/tablesorter.mas", table => "lifers" &>

	<div class="main">

		<div class="flexrow nospace">
			<span class="half">
				<h4>Multi-Year Attendees</h4>
			</span>

			<span class="half rightalign" id="lifers_buttonarea">
			</span>
		</div>

		<table id="lifers">
			<thead>
				<tr class="yellowrow smallish">
					<th>
						First
					</th>

					<th>
						Last
					</th>
					<th>
						NSDA ID #
					</th>

					<th>
						School
					</th>

					<th>
						State
					</th>

					<th>
						School ID
					</th>

					<th>
						MS Nats Count
					</th>
				</tr>
			</thead>

			<tbody>
<%perl>
				foreach my $ref (@{$years}) {

					$counts{($ref->{years} + 1)}++;

</%perl>
					<tr>
						<td>
							<% $ref->{first} %>
						</td>

						<td>
							<% $ref->{last} %>
						</td>

						<td>
							<% $ref->{nsda} %>
						</td>

						<td>
							<% $ref->{formal} || $ref->{name} %>
						</td>

						<td>
							<% $ref->{state} %>
						</td>

						<td>
							<% $ref->{chapter_nsda} %>
						</td>

						<td class="centeralign">
							<% $ref->{years} + 1 %>
						</td>
					</tr>
%				}
			</tbody>
		</table>

		<h5>Totals</h5>

%		foreach my $count (sort {$b <=> $a} keys %counts) {
			<div class="full row">
				<span class="fifth">
					<% Lingua::EN::Numbers::Ordinate::ordinate($count) %> year
				</span>

				<span class="fifth">
					<% $counts{$count} %>
				</span>
			</div>
%		}

	</div>

	<& "menu.mas",
		tourn          => $tourn,
		person         => $person,
		tourn_settings => $tourn_settings,
		whoami         => "multi_year"
	&>
