<%args>
	$dbh
	$tourn
	$tourn_settings
</%args>
<%init>

	my ($category_id, $categories) =  $m->comp("/funclib/perms/categories.mas", args  => \%ARGS);

	my $sth = $dbh->prepare("
		select
			judge.id judge, category.abbr,
			school.name school,
			person.id person, person.first, person.last,
			paradigm.value_text paradigm,
			CONVERT_TZ(paradigm.timestamp, '+00:00', tourn.tz)
		from (tourn, judge, category, person, person_setting paradigm)
			left join school on judge.school = school.id
		where 1=1
			and judge.category = ?
			and category.id    = judge.category
			and category.tourn = tourn.id
			and judge.person   = person.id
			and person.id      = paradigm.person
			and paradigm.tag   = 'paradigm'
		order by category.abbr, person.last
	");

	$sth->execute($category_id);
	my $results = $sth->fetchall_hash();

</%init>

	<& "menu.mas",
		tourn          => $tourn,
		tourn_settings => $tourn_settings,
		whoami         => "paradigms"
	&>

	<div class="main" id="main">

		<div class="flexrow ltborderbottom">
			<span class="half">
				<h4 class="nospace padbottom">Judge Paradigms</h4>
			</span>

			<span
				class = "third rightalign"
			>
				<form action="paradigms.mhtml" method="post">
					<select name="category_id" onChange="this.form.submit();">
						<option value="">Select one</option>
%						foreach my $cat (@{$categories}) {
							<option
								value="<% $cat->id %>"
								<% $cat->id == $category_id ? "selected" : "" %>
							><% $cat->name %></option>
%						}

					</select>
				</form>
			</span>
		</div>

%		foreach my $result (@{$results}) {

			<div class="row bluebordertop">

				<div class="full ltborderbottom padvertmore">
					<span class="third bigger semibold">
						<% $result->{"first"} %>
						<% $result->{"last"} %>
					</span>

					<span class="quarter bigger semibold">
						<% $result->{"school"} %>
					</span>

					<span class="tenth bigger semibold bluetext">
						<% $result->{"abbr"} %>
					</span>

					<span class="quarter bigger semibold bluetext" title="Last Updated">
						<& "/funclib/showdt.mas",
							string => $result->{"timestamp"},
							format => "murica_short"
						&>
					</span>
				</div>
				<% $result->{'paradigm'} %>
			</div>
%		}

	</div>


