<%args>
	$tourn
	$tourn_settings
	$person
	$dbh
</%args>
<%init>

	my $year = $tourn->start->year;

	my $start_year = $year - 3;
	my $start_date = $start_year."-05-01 00:00:00";

	my $end_date = $tourn->end;
	$end_date->add(months => 1);

	my $sth = $dbh->prepare("
		select
			student.id, student.first, student.last, student.nsda,
			chapter.id, chapter.nsda, chapter.name, chapter.state, chapter.formal,
			count(distinct tourn.id) count,
			GROUP_CONCAT(DISTINCT(CONCAT(tourn.start, '#', SUBSTRING(event.nsda_category, -2),'#',event.abbr)) ORDER BY tourn.start SEPARATOR 'BREAK') events

		from (student, entry_student, entry, event, tourn, chapter, tourn_setting nsda_nats, student other,
				school tsc, entry te, entry_student tes, student ts
		)

		where tourn.start > ?
			and tourn.end < ?
			and student.nsda > 0

			and tourn.id              = nsda_nats.tourn
			and nsda_nats.tag         = 'nsda_nats'
			and tourn.id              = event.tourn
			and event.id              = entry.event
			and entry.id              = entry_student.entry
			and entry.unconfirmed     = 0
			and student.nsda          = other.nsda
			and entry_student.student = other.id
			and chapter.id = tsc.chapter
			and ts.nsda = student.nsda
			and ts.id = tes.student
			and tes.entry = te.id
			and te.school = tsc.id
			and tsc.chapter != 0
			and tsc.tourn = ?

		group by student.nsda
		order by student.last, tourn.id DESC, student.last, event.nsda_category DESC
	");

	$sth->execute($start_date, DateTime::Format::MySQL->format_datetime($end_date), $tourn);

</%init>

	<div class="main">
		<span class="half">
			<h4>Four-Year Attendees</h4>
		</span>

		<span class="half rightalign" id="lifers_buttonarea">
		</span>

		<p>
			This report is according to data IN TABROOM.  Please compare to the
			data from the "Years Attended" student report to confirm with the
			NSDA Member Database.
		</p>

		<& "/funclib/tablesorter.mas", table => "lifers" &>

		<table id="lifers">
			<thead>
				<tr class="yellowrow smallish">
					<th>
						First
					</th>

					<th>
						Last
					</th>
					<th>
						ID #
					</th>

					<th>
						School
					</th>

					<th>
						State
					</th>

					<th>
						School ID
					</th>

					<th>
						Nats Count
					</th>
					<th>
						Deets
					</th>
				</tr>
			</thead>

			<tbody>
<%perl>
				while (
					my (
						$student_id, $student_first, $student_last, $student_nsda,
						$chapter_id, $chapter_nsda, $chapter_name, $chapter_state, $chapter_formal,
						$count, $events
					) = $sth->fetchrow_array()
				) {

					next unless $count > 3;
					my %years;
					my @strings = split(/BREAK/, $events);

					foreach my $split (sort @strings) {
						my ($date, $code, $event) = split(/\#/, $split);
						$date = substr($date, 0, 4);
						if ($years{$date}) {
							$years{$date} .= ', ';
						}
						$event =~ s/-//g;
						$years{$date} .= $event;
					}
</%perl>
					<tr>
						<td>
							<% $student_first %>
						</td>

						<td>
							<% $student_last %>
						</td>

						<td>
							<% $student_nsda %>
						</td>

						<td>
							<% $chapter_formal || $chapter_name %>
						</td>

						<td>
							<% $chapter_state %>
						</td>

						<td>
							<% $chapter_nsda %>
						</td>

						<td class="centeralign">
							<% $count %>
						</td>

						<td class="leftalign nospace">
%							foreach my $year (sort keys %years) {
								<div class="full flexrow nowrap">
									<span class="third">
										<% $year %>
									</span>
									<span class="twothirds">
										<% $years{$year} %>
									</span>
								</div>
%							}
						</td>
					</tr>
%				}
			</tbody>
		</table>

	</div>

	<& "menu.mas",
		tourn          => $tourn,
		person         => $person,
		tourn_settings => $tourn_settings,
		whoami         => "four_year"
	&>
