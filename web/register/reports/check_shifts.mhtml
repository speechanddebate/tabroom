<%args>
	$dbh
	$person
	$tourn
	$tourn_settings
</%args>
<%init>

	my $limit;
	my %shifts;
	my %judges;

	my ($category_id, $categories) =  $m->comp("/funclib/perms/categories.mas", args  => \%ARGS);

	if ($category_id) {
		$limit = " and category.id = ".int($category_id);

		my $sth = $dbh->prepare("
			select
				judge.id, judge.first, judge.last,
				judge.hired, judge.obligation,
				school.id school_id, school.name school_name,
				category.abbr category_abbr,
				shift.id shift_id, shift.name shift_name, shift.start shift_start,
				shiftcat.abbr shift_cat

			from (judge, category)

				left join school on judge.school = school.id
				left join strike on judge.id = strike.judge and strike.shift IS NOT NULL
				left join shift on strike.shift  = shift.id
				left join category shiftcat on shiftcat.id = shift.category

			where 1=1

				and category.tourn = ?
				$limit
				and category.id = judge.category

			order by school.name, judge.last, shift.start
		");

		$sth->execute($tourn->id);
		my $judge_strikes = $sth->fetchall_hash();


		foreach my $judge (@{$judge_strikes}) {

			unless ($judges{$judge->{id}}) {
				$judges{$judge->{id}} = {
					first         => $judge->{first},
					last          => $judge->{last},
					category_abbr => $judge->{category_abbr},
					category_id   => $judge->{category_id},
					school_id     => $judge->{school_id},
					school_name   => $judge->{school_name} || "Unaffiliated",
					obligation    => $judge->{obligation},
					hired         => $judge->{hired},
				};
			}

			if ($judge->{shift_id}) {
				unless ($shifts{$judge->{shift_id}}) {
					$shifts{$judge->{shift_id}} = {
						name  => $judge->{shift_name},
						cat   => $judge->{shift_cat},
						start => $judge->{shift_start},
					};
				}
				$judges{$judge->{id}}{shifts}{$judge->{shift_id}}++;
			}
		}
	}

</%init>

	<div class="main">

		<& "/funclib/tablesorter.mas", table => "shifts" &>

		<div class="flexrow">
			<span class="half">
				<h5>Judges with Time Constraints</h5>
			</span>

			<span
				class = "third rightalign"
			>
				<form action="check_shifts.mhtml" method="post">
					<select name="category_id" onChange="this.form.submit();">
						<option value="">Select one</option>
%						foreach my $cat (@{$categories}) {
							<option
								value="<% $cat->id %>"
								<% $cat->id == $category_id ? "selected" : "" %>
							><% $cat->name %></option>
%						}

					</select>
				</form>
			</span>

			<span
				class = "sixth rightalign"
				id    = "shifts_buttonarea"
			>
			</span>
		</div>

		<table id="shifts">

			<thead>
				<tr>
					<th>
						School
					</th>

					<th>
						First
					</th>

					<th>
						Last
					</th>

					<th>
						Category
					</th>

%					foreach my $shift_id (sort {$shifts{$a}{"start"} cmp $shifts{$b}{start}} keys %shifts) {
						<th class="centeralign">
							<% $shifts{$shift_id}{"name"} %>
							<% $shifts{$shift_id}{"cat"} %>
						</th>
%					}

					<th>
						Rounds
					</th>

					<th>
						Max
					</th>
				</tr>
			</thead>

			<tbody>
<%perl>
				foreach my $judge_id (
					sort {
						$judges{$a}{school_name} cmp $judges{$b}{school_name}
						|| $judges{$a}{"last"} cmp $judges{$b}{"last"}
				} keys %judges) {

					my $judge = $judges{$judge_id};
</%perl>
					<tr class="<% $judge_id %>">

						<td class='nospace'>
							<a
								href="/register/school/judges.mhtml?school_id=<% $judge->{school_id} %>"
								class="full white padleft"
							><% $judge->{school_name} %></a>
						</td>

						<td class='nospace'>
							<a
								href="/register/judge/edit.mhtml?judge_id=<% $judge_id %>"
								class="full white padleft"
							><% $judge->{first} %></a>
						</td>

						<td class='nospace'>
							<a
								href="/register/judge/edit.mhtml?judge_id=<% $judge_id %>"
								class="full white padleft"
							><% $judge->{last} %></a>
						</td>

						<td class="centeralign">
							<% $judge->{category_abbr} %>
						</td>

%						foreach my $shift_id (sort {$shifts{$a}{"start"} cmp $shifts{$b}{start}} keys %shifts) {
							<td class="centeralign semibold redtext">
								<% $judge->{shifts}{$shift_id} ? "X" : "" %>
							</td>
%						}

						<td class="centeralign">
							<% $judge->{obligation} + $judge->{hired} %>
						</td>

%						my $max = $m->comp("/funclib/judge_max_prelims.mas", judge => $judge_id);

						<td class="centeralign <% ($max < $judge->{obligation} + $judge->{hired}) ? "redtext semibold" : "" %>">
							<% $max %>
						</td>

					</tr>
%				}
			</tbody>

		</table>

	</div>

	<& "menu.mas",
		tourn          => $tourn,
		person         => $person,
		tourn_settings => $tourn_settings,
		whoami         => "shifts"
	&>

