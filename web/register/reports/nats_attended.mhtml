<%args>
	$dbh
	$tourn
	$tourn_settings
	$mode => "pdf"
</%args>
<%init>

	our $pagesize = 45;
	our $line = $pagesize + 2;
	our $counter;

	$m->comp("/funclib/nsda/nats_appearances.mas", tourn => $tourn);

	my $sth = $dbh->prepare("
		select chapter.name, chapter.state,
				chapter.formal, school.name school_name,
				chapter.nsda nsda,
				district.name district_name, district.code district_code,
			( select nats_appearances.value
				from chapter_setting nats_appearances
				where nats_appearances.chapter = school.chapter
				and nats_appearances.tag = 'nats_appearances'
			) nats_appearances

		from (tourn, school, chapter, student, entry_student es, event, entry )

			left join district on district.id = school.district

		where 1=1
			and tourn.id = ?
			and school.tourn = tourn.id
			and school.chapter = student.chapter
			and student.id = es.student
			and es.entry = entry.id
			and entry.active = 1
			and entry.event = event.id
			and event.tourn = tourn.id
			and school.chapter = chapter.id

		group by chapter.id
		order by chapter.state, chapter.formal, chapter.name
	");

	$sth->execute($tourn->id);
	my $schools = $sth->fetchall_hash();

</%init>

	<& "menu.mas",
		tourn          => $tourn,
		tourn_settings => $tourn_settings,
		whoami         => "nats_attended"
	&>

	<div class="main">

		<span class="threequarters nospace">
			<h4>Schools &amp; Appearances</h4>
		</span>

		<span
			class = "quarter rightalign"
			id    = "school_appearances_buttonarea"
		></span>

		<p class="semibold centeralign bluetext">
			This report includes the current year's Nationals appearance
		</p>

		<& "/funclib/tablesorter.mas", table => "school_appearances" &>

		<table id="school_appearances">

			<thead>
				<tr class="yellowrow">

					<th>
						School
					</th>

					<th>
						State
					</th>

					<th>
						NSDA
					</th>

					<th>
						District
					</th>

					<th>
						DCode
					</th>

					<th>
						Appearances
					</th>

				</tr>
			</thead>

			<tbody>
%				foreach my $school (@{$schools}) {

					<tr>
						<td>
							<% $school->{formal} || $school->{name} || $school->{school_name} %>
						</td>

						<td class="centeralign">
							<% $school->{state} %>
						</td>

						<td class="centeralign">
							<% $school->{nsda} %>
						</td>

						<td>
							<% $school->{district_name} %>
						</td>

						<td class="rightalign">
							<% $school->{district_code} %>
						</td>

						<td class='rightalign'>
							<% $school->{nats_appearances} + 1 %>
						</td>
					</tr>
%				}
			</tbody>
		</table>
	</div>

