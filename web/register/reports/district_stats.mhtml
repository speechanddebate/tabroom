<%args>
	$dbh
	$person
	$tourn
	$tourn_settings
</%args>
<%init>

	# This would be the 140th simple query that is unnecessarily complicated by
	# Worlds.

	my $sth = $dbh->prepare("
		select
			district.code,
			district.name,
			district.location,
			(
				select count(distinct chapter.id)
					from chapter, student, entry_student es, entry, event
				where 1=1
					and chapter.district  = district.id
					and chapter.id        = student.chapter
					and student.id        = es.student
					and es.entry          = entry.id
					and entry.event       = event.id
					and entry.unconfirmed = 0
					and event.tourn       = tourn.id
			) as chapters,

			(
				select count(distinct entry.id)
				from school, entry
				where 1=1
					and school.tourn      = tourn.id
					and school.district   = district.id
					and school.id         = entry.school
					and entry.unconfirmed = 0

			) as entries,
			(
				select count(distinct es.student)
				from school, entry, entry_student es
				where 1=1
					and school.tourn      = tourn.id
					and school.district   = district.id
					and school.id         = entry.school
					and entry.unconfirmed = 0
					and entry.id = es.entry

			) as students

			from district, tourn
			where tourn.id = ?
			order by chapters DESC
	");

	$sth->execute($tourn->id);

	my $districts = $sth->fetchall_hash();

</%init>

	<& "menu.mas",
		tourn          => $tourn,
		person         => $person,
		tourn_settings => $tourn_settings,
		whoami         => "district_stats"
	&>

	<div class="main">

		<div class="flexrow full">
			<span class="seveneighths nospace">
				<h2>Attendance By District</h2>
			</span>

			<span
				class ="eighth nospace rightalign"
				id    = "district_stats_buttonarea"
			>
			</span>
		</div>

		<& "/funclib/tablesorter.mas", table => "district_stats" &>

		<table id="district_stats">

			<thead>
				<tr>
					<th>
						District
					</th>

					<th>
						Code
					</th>

					<th>
						Location
					</th>

					<th>
						Schools
					</th>

					<th>
						Students
					</th>

					<th>
						Entries
					</th>
				</tr>
			</thead>

			<tbody>
%				foreach my $ref (@{$districts}) {

%					next if $ref->{chapters} < 1;
					<tr>
						<td>
							<% $ref->{name} %>
						</td>

						<td class="centeralign">
							<% $ref->{ code } %>
						</td>

						<td class="centeralign">
							<% $ref->{location } %>
						</td>

						<td class="centeralign">
							<% $ref->{chapters } %>
						</td>

						<td class="centeralign">
							<% $ref->{students } %>
						</td>

						<td class="centeralign">
							<% $ref->{entries } %>
						</td>
					</tr>
%				}
			</tbody>
		</table>
	</div>
