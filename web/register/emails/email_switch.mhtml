<%args>
	$dbh
	$person
	$tourn
	$tourn_settings => undef
	$email_id       => undef
	$setting_name   => undef
	$property_name  => undef
	$property_value => 0
</%args>
<%init>

	$m->clear_buffer();
	$r->content_type('application/json');

	unless ($email_id) {
		$m->print('{ "error": true, "message": "No email ID sent"}');
		$m->abort();
	}

	unless ($property_name || $setting_name) {
		$m->print('{ "error": true, "message": "No property to change sent"}');
		$m->abort();
	}

	my $email = Tab::Email->retrieve($email_id);

	unless ($email) {
		$m->print('{ "error": true, "message": "No email found for ID '.$email_id.'"}');
		$m->abort();
	}

	my $message;
	my $extra;

	if ($property_name) {
		$email->$property_name($property_value);
		$email->update();
		$message = "Email ".$email->id." ".$email->subject." property $property_name changed to $property_value";
	}

    my $response = ({
		error   => \0,
		message => $message
    });

	my $now = DateTime->now();

	$m->comp("/funclib/log.mas",
		type        => 'tabbing',
		tourn       => $tourn->id,
		person      => $person->id,
		description => $message
	);

	Tab::debuglog("hello darlinkg");

    $m->print(JSON::encode_json($response));
	$m->abort();

</%init>
