<%args>
	$dbh
	$tourn
	$tourn_settings
	$person
	$email_id => undef
</%args>
<%init>

	my $email = Tab::Email->retrieve($email_id) if $email_id;

	use Text::Wrap
    $Text::Wrap::columns = 72;

	my $switch;

</%init>

%	if ($tourn->webname) {
		<&
			"menu.mas",
			tourn          => $tourn,
			tourn_settings => $tourn_settings,
			email_id       => $email_id,
			whoami         => "index"
		&>
%	}

	<div class="main">

%		if ($email_id) {

			<div class="full flexrow padbottom">
				<span class="half">
					<h4 class="nospace">Previously sent message</h4>
				</span>

				<span
					class = "fifth semibold padright"
					title = "Use this switch to change whether this email appears on the public website archive"
				>
					<label
						for="<% $email->id %>"
						class="padrightless padvertless rightalign"
					>
						On Web Archive
					</label>
				</span>
				<span class="tenth">
					<& "/funclib/bool_switch.mas",
						tag      => $email->id,
						email_id => $email->id,
						smaller  => 'yeppers',
						invert   => 1,
						property => 'hidden',
						value    => ($email->hidden ? 1 : 0),
						url      => "email_switch.mhtml"
					&>
				</span>

				<span class="fifth rightalign">
					<form action="compose.mhtml" method="post">
						<input
							type  = "hidden"
							name  = "email_id"
							value = "<% $email ? $email->id : ""%>"
						>

						<input
							type  = "submit"
							value = " Edit/Send Again "
						>
					</form>
				</span>
			</div>

			<div class="row">
				<span class="fifth semibold bluetext padvert">
					Tournament
				</span>

				<span class="fourfifths">
					<% $email->tourn->name %>
				</span>
			</div>

			<div class="row">
				<span class="fifth semibold bluetext padvert">
					Subject
				</span>

				<span class="fourfifths">
					<% $email->subject %>
				</span>
			</div>

%			if ($email->person) {
				<div class="row">
					<span class="fifth semibold bluetext padvert">
						Sent By
					</span>

					<span class="fourfifths">
						<% $email->person->first." ".$email->person->last %> (<% $email->person->email %>)
					</span>
				</div>
%			}

%			my $sender_account;

%			if ($email->sender != $email->person) {
%				$sender_account = $email->sender->first." ".$email->sender->last." &lt;".$email->sender->email."&gt;";
				<div class="row">
					<span class="fifth semibold bluetext padvert">
						Sent As
					</span>

					<span class="fourfifths">
						<% $sender_account %>
					</span>
				</div>
%			}

% 			if ($email && $email->sender_raw && $email->sender_raw != $email->person->email) {
%				my $sender_raw = $email->sender_raw;
%				$sender_raw =~ s/\</&lt;/g;
%				$sender_raw =~ s/\>/&gt;/g;
%				if ($sender_raw ne $sender_account)  {
					<div class="row">
						<span class="fifth semibold bluetext padvert">
							Sent As
						</span>

						<span class="fourfifths">
							<% $sender_raw %>
						</span>
					</div>
%	 			}
% 			}

			<div class="row">
				<span class="fifth semibold bluetext padvert">
					Sent to
				</span>

				<span class="fourfifths">
					<% $email->sent_to %>
				</span>
			</div>

			<div class="row">
				<span class="fifth semibold bluetext padvert">
					Sent on
				</span>

				<span class="fourfifths">
					<% Tab::nicedt($email->sent_at->set_time_zone($tourn->tz)) %>
				</span>
			</div>

%			if ($email->hidden) {
				<div class="row padsetting centeralign redtext semibold">
					Email is NOT included on the tournament web archive
				</div>
%			}

			<div class="full nospace martopmore padtopmore padbottom">
				<h5 class="nospace">Message</h5>
			</div>

			<div class="full padtop ltborder bigger">
				<% $email->content %>
			</div>

%			my $metadata = $email->metadata;
%			if ($metadata) {
%				$metadata =~ s/\n/<\/p><p>/g;
%				$metadata =~ s/,/, /g;
				<div class="full padtop nospace">
					<h5 class="nospace">Metadata</h5>
				</div>

				<div class="full padtopmore wrap smallish">
					<p>
					<% $metadata %>
				</div>
%			}
%		} elsif (!$tourn->webname) {

			<h4>You cannot send email without a tournament webname</h4>

			<p class='padtopmore bigger' style="line-height: 2em;">
				You must set a
				<a href="/setup/tourn/main.mhtml?tourn_id=<% $tourn->id %>" class="biggish redtext link-underline semibold inline">tournament webname</a>
				to send emails now.  Because of various filtering nonsense by other ISPs we send mail to or through,
				your email must now go out as a unique address.  Those emails will go out as "yourwebname@www.tabroom.com"
				which means setting a web name is required.
			</p>

			<div class="evenrow rightalign">
				<span class="third centeralign">
					<a
						href="/setup/tourn/main.mhtml?tourn_id=<% $tourn->id %>"
						class="invert buttonwhite bluetext"
					>Set Webname</a>
				</span>
			</div>

%		}

	</div>

