<%args>
	$tourn
	$sort_by => undef
	$circuit => undef
</%args>
<%perl>

	return unless $tourn;
	my $sort = "order by region.code, region.name";
	$sort = "order by region.name, region.code" if $sort_by eq "name";
	$sort .= ", registered ";

	my $limit;

	if ($circuit) {
		$limit = "and region.circuit = ".int($circuit);
	} else {
		$limit = "and region.tourn = ".int($tourn);
	}

	if ($ARGS{raw}) {

		my $dbh = Tab::DBI->db_Main();

		my $sth = $dbh->prepare("
			select distinct region.*,
				(select registered.value
					from region_setting registered
				where registered.region = region.id
					and registered.tag = ?
					and registered.value = 1
				) registered
			from (region)
			where 1=1
				$limit
				or exists (
					select school.id
					from school
					where school.tourn = ?
					and school.region = region.id
				)
			group by region.id
			$sort
		");

		$sth->execute("registered_$tourn", $tourn->id);
		my $regions = $sth->fetchall_hash();
		return $regions;

	} else {

		Tab::Region->set_sql( by_tourn => "
			select distinct region.*,
				(select registered.value
					from region_setting registered
				where registered.region = region.id
					and registered.tag = ?
					and registered.value = 1
				) registered
			from (region)
			where 1=1
				$limit
			or exists (
				select school.id
				from school
				where school.tourn = ?
				and school.region = region.id
			)
			group by region.id
			$sort
		");

		my @regions = Tab::Region->search_by_tourn("registered_".$tourn->id, $tourn->id);

		@regions = sort {length($a->code) <=> length($b->code)} @regions;

		return @regions;

	}

</%perl>
