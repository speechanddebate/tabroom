<%args>
	$category
	$tag   => undef
	$all   => undef
	$value => undef
</%args>
<%init>

	my $dbh = Tab::DBI->db_Main();

	if ($all) {

		my $sth = $dbh->prepare("
			select distinct judge_setting.*
				from judge_setting, judge
			where judge.category = ?
			and judge.id = judge_setting.judge
		");

		$sth->execute($category->id);
		my $refs = $sth->fetchall_hash();

		my %settings;

		foreach my $ref (@{$refs}) {

			if ($value) {

				if ($ref->{value} eq "json")  {
					$settings{$ref->{judge}}{$ref->{tag}} = eval {
						return JSON::decode_json($ref->{value_text});
					};
				} elsif ($ref->{value} eq "text")  {
					$settings{$ref->{judge}}{$ref->{tag}} = $ref->{value_text};
				} elsif ($ref->{value} eq "date") {
					$settings{$ref->{judge}}{$ref->{tag}} = eval {
						return DateTime::Format::MySQL->parse_datetime($ref->{value_date});
					};
				} else {
					$settings{$ref->{judge}}{$ref->{tag}} = $ref->{value};
				}
			}
		}

		return %settings;

	} elsif ($tag) {

		Tab::JudgeSetting->set_sql( by_category => "
			select distinct judge_setting.*
			from judge_setting, judge
			where judge.category = ?
			and judge.id = judge_setting.judge
			and judge_setting.tag = ?
		");

		return Tab::JudgeSetting->search_by_category($category->id, $tag);

	}

	return;

</%init>
