<%args>
	$person
	$round => undef
</%args>
<%init>

	my $event = $round->event;
	my $now = DateTime->now();

	Tab::ChangeLog->create({
		round       => $round,
		event       => $event,
		person      => $person,
		tag         => "tabbing",
		description => "Creating round ranks report for Nationals",
	});

	Tab::Autoqueue->create({
		tag       => "scores",
		event     => $event,
		round     => $round,
		active_at => $now,
	});

	return;

</%init>
