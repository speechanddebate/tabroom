<%args>
	$tourn
	$tourn_settings
	$err => undef
</%args>

%	my $symbol = $tourn_settings->{'currency'};

	<& menu.mas,
		chosen => "entry",
		tourn_settings => $tourn_settings,
		tourn => $tourn
	&>

	<div class="main">

		<h2>Entry Fees</h2>

		<form action="entry_save.mhtml" method="post">

		<div class="row flexrow">

			<span class="half nospace">
				<label for="invoice_waitlist">
					<span class="threequarters padleft">
						Include waitlisted entries on invoices
					</span>

					<span class="quarter centeralign">
						<input
							type  = "checkbox"
							id	= "invoice_waitlist"
							name  = "invoice_waitlist"
							value = "1"
							<% $tourn_settings->{"invoice_waitlist"} ? 'checked="checked"' : "" %>
						>
					</span>
				</label>
			</span>

			<span class="half nospace">
				<label for="judges_waitlist">
					<span class="threequarters padleft">
						Include waitlisted entries towards judge obligations
					</span>

					<span class="quarter centeralign">
						<input
							type  = "checkbox"
							id	= "judges_waitlist"
							name  = "judges_waitlist"
							value = "1"
							<% $tourn_settings->{"judges_waitlist"} ? 'checked="checked"' : "" %>
						>
					</span>
				</label>
			</span>
		</div>

%		my $currency = $tourn_settings->{'currency'};

		<div class="row flexrow">

			<span class="twofifths padleft">
				Currency Symbol for invoices
			</span>

			<span class="tenth centeralign padvertless padright">
				<input
					type  = "text"
					name  = "currency"
					value = "<% $currency ? $currency : '$' %>">
			</span>

%			my $alterna_state = $tourn_settings->{"fees_alternate_state"};

			<span class="threetenths padleft">
				Charge alternate fees to schools from
			</span>

			<span class="fifth rightalign padright">
				<select
					name  = "fees_alternate_state"
					class = "chosen fixedmed">
					<& "/funclib/state_select.mas", state => $alterna_state &>
				</select>
			</span>
		</div>

		<h4 class="martop">
			Events/Divisions
		</h4>

%		my $switch;

		<div class="row flexrow">

%			foreach my $event (sort {$a->name cmp $b->name} $tourn->events) {

				<span class="half flexrow">

					<span class="threetenths grow padleft">
						<% $event->name %>
					</span>

					<span class="tenth rightalign padrightless">
						<% $symbol %>
					</span>

					<span class="fifth">
						<input
							type  = "number"
							name  = "<% $event->id %>"
							value = "<% $event->fee %>"
							size  = "6"
							step  = "0.01"
						>
					</span>

%					if ($alterna_state) {
						<span class="twofifths grow flexrow">
							<span class="half rightalign">
								From <% $alterna_state %>:
							</span>
							<span class="half">
								<input
									type  = "number"
									name  = "alt_state_<% $event->id %>"
									value = "<% $event->setting("alt_state_fee") %>"
									size  = "6"
									step  = "0.01"
								>
							</span>
						</span>
%					}

				</span>

%				if ($switch++ % 2) {
					</div>
					<div class="row flexrow">
%				}
% 			}
		</div>

		<div class="libl rightalign">
			<span class='third centeralign'>
				<input
					type  = "submit"
					value = "Save Entry Fees"
				>
			</span>
		</div>

		</form>

	</div>

