<%args>
	$dbh
	$set_id
	$person
</%args>
<%init>

	my $protocol = Tab::Protocol->retrieve($set_id);
	my $msg;

	my $sth = $dbh->prepare("
		update round set protocol = NULL where protocol = ?
	");

	my $tb_sth = $dbh->prepare("
		delete from tiebreak were protocol = ?
	");

	if ($set) {
		$sth->execute($protocol->id);
		$tb_sth->execute($protocol->id);
		$msg = $person->first." uses <strong>TIEBREAK ATTACK</strong>.<br/>  It's super effective! <br/><br/> Set ".$set->name." destroyed ";
		$set->delete;
	}

	$m->redirect("tiebreaks.mhtml?msg=$msg");

</%init>
