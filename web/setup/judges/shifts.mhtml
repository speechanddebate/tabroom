<%args>
	$tourn
	$tourn_settings
	$category_id
	$perms
</%args>
<%init>

	my ($category, $category_settings, $categories) = $m->comp(
		'perms.mas',
		tourn       => $tourn,
		perms       => $perms,
		category_id => $category_id
	);

	unless ($category) {
		$m->comp("/funclib/abort.mas",
			message => "No judge category found for ID $category_id"
		);
	}

	my $tz = $tourn->tz;
	$tz = "UTC" unless $tz;

	my @days;
	my $weekend;
	my $diff_month;

	if ($category->setting("weekend")) {

		$weekend = Tab::Weekend->retrieve($category->setting('weekend'));

		@days = $m->comp("/funclib/tourn_days.mas",
					tourn   => $tourn,
					weekend => $weekend
				);
	} else {

		@days = $m->comp("/funclib/tourn_days.mas",
			tourn => $tourn
		);

		my $already = $days[0]->month;
		foreach my $day (@days) {
			$diff_month++ if $already ne $day->month;
		}
	}

	my $rounds_per = $category_settings->{"rounds_per"};
	my %other_categories;

	foreach my $cat_id (keys %{$categories}) {
		next if $cat_id == $category_id;
		$other_categories{$cat_id} = $categories->{$cat_id};
	}

</%init>

    <& "menu.mas",
		category_id       => $category_id,
		tourn             => $tourn,
		tourn_settings    => $tourn_settings,
		page              => "shifts",
		perms             => $perms,
		categories        => $categories,
	&>

	<div class="main">

		<h2>
			<% $category->name %>
		</h2>

		<&
			"tabbar.mas",
			tourn             => $tourn,
			tourn_settings    => $tourn_settings,
			category_settings => $category_settings,
			whoami            => "shifts",
			category          => $category
		&>

		<form
			action="clone_shifts.mhtml"
			method="post"
		>
		<div class="flexrow full">

			<span class="threesevenths">
				<h4>Judging time shifts</h4>
			</span>

%			if ( (scalar %other_categories) > 0 ) {
				<span class="foursevenths flexrow">
					<span class="threetenths bluetext semibold">
						Clone shifts from
					</span>

					<span class="half nospace centeralign grow">
						<input
							type  = "hidden"
							name  = "target_id"
							value = "<% $category->id %>"
						>

						<select name = "origin_id" >
							<option value=""></option>
<%perl>
							foreach my $category_id (
								sort {$other_categories{$a}{"abbr"} cmp $other_categories{$b}{"abbr"}}
								keys %other_categories
							) {
</%perl>
								<option
									value="<% $category_id %>"
								><% $other_categories{$category_id}{"name"} %></option>
%							}
						</select>
					</span>

					<span class="fifth bluetext semibold centeralign">
						<input
							type  = "submit"
							value = "Clone"
						>
					</span>
				</span>
%			}
			</div>
		</form>


		<div class="full padleft padright">

			<p>

				These timeblocks allow registering coaches to mark judges as
				<span class="inline semibold redtext">unavailable</span> during
				the shifts you specify.

%			if ($rounds_per) {

				However, you cannot assess fines for part time judges when
				doing by round committments.  It doesn't make sense to charge
				someone for a part time committment when they're also
				specifying how many rounds they can judge.

%			} else {

				The fees will be charged if a school is under their burden
				during that shift; so if a school owes 2 judges and only 1
				judge is free on Friday night, the Friday night fine will be
				charged. However, if the school brings 3 judges, of which 2 are
				always available, the fine will not be charged.
%			}

			</p>

			<p>
				Shifts marked "signup" will be shown on the public judge signup
				sheet, if enabled.
			</p>

			<p>
				Shifts marked "strike" will be shown to registering coaches of
				schools to limit their judges availabilty.
			</p>

			<p>
				Shifts marked "both" will be shown in both places.
			</p>

		</div>

		<& "/funclib/tablesorter.mas",
			table     => "shifts",
			nobuttons => 'nope'
		&>

		<form
			action = "shifts_save.mhtml"
			method = "post"
		>

		<input
			type  = "hidden"
			name  = "category_id"
			value = "<% $category->id %>"
		>

		<table id="shifts">

			<thead>

				<tr class="yellowrow">
					<th class="smallish">
						Name
					</th>

					<th class="smallish">
						Type
					</th>

%					unless ($rounds_per) {
						<th class="smallish">
							Fee
						</th>
						<th
							class = "smallish"
							title = "Warns coaches no partial time hires are available and obligations must be met in all time blocks"
						>
							No Hires
						</th>
%					}

					<th class="smallish">
						Timespan
					</th>

					<th>
					</th>
				</tr>

			</thead>
			<tbody>
<%perl>

			my @shift_types = ("both", "signup", "strike");

			my $shifts;

			foreach my $shift (
				sort {$a->type <=> $b->type}
				$category->shifts
			) {

				$shifts++;

				my $shift_start = $shift->start->set_time_zone($tz);
				my $shift_end = $shift->end->set_time_zone($tz);
</%perl>
				 <tr>
					<td
						data-text="<% $shift->name %>"
					>
						<input
							type  = "text"
							class = "full"
							name  = "<% $shift->id %>_name"
							value = "<% $shift->name %>"
						>
					</td>

					<td
						class     = "centeralign"
						data-text = "<% $shift->type %>"
					>

						<select
							name  = "<% $shift->id %>_type"
						>
%							foreach my $type (@shift_types) {
								<option
									value="<% $type %>"
									<% $type eq $shift->type ? 'selected="selected"' : "" %>
								><% ucfirst($type) %></option>
%							}
						</select>
					</td>

%					unless ($rounds_per) {
						<td class="centeralign">
							<input
								type  = "number"
								class = "smaller"
								min   = "0"
								max   = "99999"
								name  = "<% $shift->id %>_fine"
								value = "<% $shift->fine %>"
								size  = "4"
							>
						</td>
						<td class="centeralign">
							<label for="<% $shift->id %>_no_hires" class="full hover">
								<input
									type  = "checkbox"
									name  = "<% $shift->id %>_no_hires"
									id    = "<% $shift->id %>_no_hires"
									value = "1"
									<% $shift->no_hires ? "checked" : "" %>
								>
							</label>
						</td>
%					}

					<td class="nospace">
						<div class="full smallish borderbottom ltborderleft ltborderright flexrow">
%							if (scalar @days > 1) {
								<span class="fifth semibold centeralign">
									Start
								</span>

								<span class="twofifths">
									<select name="<% $shift->id %>_start_day">
%									foreach my $day (@days) {
										<option
											id    = "start_<% $shift->id."-".$day->epoch %>"
											value = "<% Tab::pickerdate($day) %>"
											<% ($shift_start->day == $day->day && $shift_start->month eq $day->month) ? "selected" : "" %>
										>
											<% $day->day_abbr %>
											<% $diff_month ? $day->month_abbr : "" %>
											<% Lingua::EN::Numbers::Ordinate::ordinate($day->day) %>
										</option>
%									}
									</select>
								</span>

								<span class="twofifths padleft padright">
									<& /funclib/timepicker.mas,
										name => $shift->id."_start",
										time => $shift_start,
									&>
								</span>

%							} else {

%								my $day = $days[0];
								<span class="third semibold padleft">
									Start
								</span>
								<span class="third padleft">
									<& /funclib/timepicker.mas,
										name => $shift->id."_start",
										time => $shift_start,
									&>
								</span>
								<span class="third padright rightalign">
									<% $day->day_abbr %>
									<% $diff_month ? $day->month_abbr : "" %>
									<% Lingua::EN::Numbers::Ordinate::ordinate($day->day) %>
								</span>
%							}
						</div>

						<div class="full smallish ltborderleft ltborderright flexrow">
%							if (scalar @days > 1) {
								<span class="fifth semibold centeralign">
									End
								</span>

								<span class="twofifths">
									<select name="<% $shift->id %>_end_day">
%									foreach my $day (@days) {
										<option
											id    = "end_<% $shift->id."-".$day->epoch %>"
											value = "<% Tab::pickerdate($day) %>"
											<% ($shift_end->day == $day->day && $shift_end->month eq $day->month) ? "selected" : "" %>
										>
											<% $day->day_abbr %>
											<% $diff_month ? $day->month_abbr : "" %>
											<% Lingua::EN::Numbers::Ordinate::ordinate($day->day) %>
										</option>
%									}
									</select>
								</span>

								<span class="twofifths padleft padright">
									<& /funclib/timepicker.mas,
										name => $shift->id."_end",
										time => $shift_end,
									&>
								</span>

%							} else {
								<span class="third semibold padleft">
									End
								</span>
								<span class="third padleft padright">
									<& /funclib/timepicker.mas,
										name => $shift->id."_end",
										time => $shift_end,
									&>
								</span>
								<span class="third padright">
								</span>
%							}
						</div>
					</td>

					<td class="centeralign padless">
						<a
							class = "buttonwhite redtext hover marno fa fa-sm fa-trash"
							href  = "shift_rm.mhtml?shift_id=<% $shift->id %>"
							<& "/funclib/confirm.mas",
								warn => "This will delete this shift and time strikes.  Are you sure?"
							&>
						>
						</a>
					</td>
				</tr>
% 			}

			<tr class="row <% $shifts ? "bluebordertop" : "" %>">
				<td class="centeralign">
					<input
						type        = "text"
						name        = "new_name"
						class       = "full"
						placeholder = "Add new..."
					>
				</td>

				<td class="centeralign nospace">
					<select
						name  = "new_type"
					>
%						foreach my $type (@shift_types) {
							<option
								value="<% $type %>"
							><% ucfirst($type) %></option>
%						}

					</select>
				</td>

%				unless ($rounds_per) {
					<td class="centeralign">
						<input
							type  = "number"
							class = "smaller"
							min   = "0"
							max   = "99999"
							name  = "new_fine"
							size  = "4"
						>
					</td>

					<td class="centeralign">
						<label for="new_no_hires" class="full hover">
							<input
								type  = "checkbox"
								name  = "new_no_hires"
								id    = "new_no_hires"
								value = "1"
							>
						</label>
					</td>
% 				}

				<td class="nospace">
					<div class="full smallish borderbottom ltborderleft ltborderright flexrow">
%						if (scalar @days > 1) {
							<span class="fifth semibold centeralign">
								Start
							</span>

							<span class="twofifths">
								<select name="new_start_day">
%									foreach my $day (@days) {
										<option
											value = "<% Tab::pickerdate($day) %>"
										>
											<% $day->day_abbr %>
											<% $diff_month ? $day->month_abbr : "" %>
											<% Lingua::EN::Numbers::Ordinate::ordinate($day->day) %>
										</option>
%									}
								</select>
							</span>

							<span class="twofifths padleft padright">
								<& /funclib/timepicker.mas,
									name => "new_start"
								&>
							</span>

%						} else {

							<span class="third semibold padleft">
								Start
							</span>
							<span class="third padleft">
								<& /funclib/timepicker.mas,
									name => "new_start"
								&>
							</span>
%						}
					</div>

					<div class="full smallish ltborderleft ltborderright flexrow">
%						if (scalar @days > 1) {
							<span class="fifth semibold centeralign">
								End
							</span>

							<span class="twofifths">
								<select name="new_end_day">
%									foreach my $day (@days) {
										<option
											value = "<% Tab::pickerdate($day) %>"
										>
											<% $day->day_abbr %>
											<% $diff_month ? $day->month_abbr : "" %>
											<% Lingua::EN::Numbers::Ordinate::ordinate($day->day) %>
										</option>
%									}
								</select>
							</span>

							<span class="twofifths padleft padright">
								<& /funclib/timepicker.mas,
									name => "new_end"
								&>
							</span>

%						} else {
							<span class="third semibold padleft">
								End
							</span>
							<span class="third padleft">
								<& /funclib/timepicker.mas,
									name => "new_end"
								&>
							</span>
%						}
					</div>
				</td>

				<td>
				</td>
			</tr>
			</tbody>
		</table>

		<div class="libl rightalign">
			<span class="third centeralign padvert">
				<input
					type  = "submit"
					value = " Save Shifts"
				>
			</span>
		</div>
		</form>
	</div>
