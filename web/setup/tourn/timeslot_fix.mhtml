<%args>
	$tourn
</%args>
<%init>

	my %cache;

	foreach my $event ($tourn->events) {
		foreach my $round ($event->rounds) {

			my $timeslot = $round->timeslot;

			if ($timeslot->tourn->id != $tourn->id) {

				if (not defined $cache{$timeslot->id}) {
					$cache{$timeslot->id} = $timeslot->copy({
						tourn => $tourn->id
					});
				}

				$round->timeslot($cache{$timeslot->id});
				$round->update();
			}
		}
	}

	$m->print("<p>Fin</p>");

</%init>
