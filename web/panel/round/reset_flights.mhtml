<%args>
	$dbh
	$round_id
	$person
	$person_settings
	$tourn
	$perms
</%args>
<%init>

	my $round = Tab::Round->retrieve($round_id);

	unless ($round > 0) {
		$m->comp('/funclib/abort.mas', message => "Invalid round id $round_id sent");
	}

	my %events = $m->comp("/funclib/perms/events.mas",
		tourn   => $tourn,
		perms   => $perms,
		limited => 1
	);

	unless ($events{$round->event->id}) {
		$m->comp("/funclib/abort.mas", message => "You are not authorized to change that event");
	}

	my $limiter = " and p2.letter > panel.letter and p2.id != panel.id ";

	if ($ARGS{"bracket"}) {
		$limiter = " and p2.bracket <= panel.bracket and p2.id != panel.id ";
	}

	my $sth = $dbh->prepare("
		 update panel, panel p2, ballot, ballot b2
			 set panel.flight = 1, p2.flight = 2
		 where panel.round = ?
			 and p2.round = panel.round
			 and p2.letter > panel.letter
			 and p2.id = b2.panel
			 and panel.id = ballot.panel
			 and ballot.judge = b2.judge
	");

	$sth->execute($round->id);

	my $log = Tab::ChangeLog->create({
		tag         => "tabbing",
		description => "Reset the section's flights",
		person      => $person,
		round       => $round,
	});

	my $msg = "Flights reset";

	if ($ARGS{return}) {
		return $msg;
	}
	$m->redirect("/panel/schemat/show.mhtml?round_id=".$round->id."&msg=$msg");

</%init>
