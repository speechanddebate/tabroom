<%args>
	$dbh
	$round_id
	$person
	$person_settings
	$tourn
	$perms
</%args>
<%init>

	my $round = Tab::Round->retrieve($round_id);

	unless ($round > 0) {
		$m->comp('/funclib/abort.mas', message => "Invalid round id $round_id sent");
	}

	my %events = $m->comp("/funclib/perms/events.mas",
		tourn   => $tourn,
		perms   => $perms,
		limited => 1
	);

	unless ($events{$round->event->id}) {
		$m->comp("/funclib/abort.mas", message => "You are not authorized to change that event");
	}

	my $sth = $dbh->prepare("
		select
			panel.id, panel.letter, panel.bracket, panel.flight,

			(select
				rs.value
				from round_setting rs
				where rs.round = panel.round
				and rs.tag = 'no_bracketed_flights'
			) no_brackets,

			(select judge.id
				from judge, ballot
				where ballot.panel = panel.id
				and ballot.judge = judge.id
				group by judge.id
				order by ballot.chair DESC, judge.id
				limit 1
			) as judge,

			(select count(pref1.id)
				from entry_setting pref1, ballot
				where pref1.tag = 'preferred_flight'
				and pref1.value = 1
				and pref1.entry = ballot.entry
				and ballot.panel = panel.id
			) as pref1,

			(select count(pref2.id)
				from entry_setting pref2, ballot
				where pref2.tag = 'preferred_flight'
				and pref2.value = 2
				and pref2.entry = ballot.entry
				and ballot.panel = panel.id
			) as pref2,

			(
				select SUM(
					(	select count(entry.id)
							from entry, ballot
						where ballot.entry = entry.id
							and entry.ada = 1
							and entry.id = ballot.entry
							and ballot.panel = panel.id
					) + (
						select count(judge.id)
							from judge, ballot
						where ballot.judge = judge.id
							and judge.ada = 1
							and judge.id = ballot.judge
							and ballot.panel = panel.id
					)
				)
			) as ada_count

		from panel
			where 1=1
			and panel.round = ?
			and panel.bye = 0
		group by panel.id
	");

	$sth->execute($round->id);

	my $panels = $sth->fetchall_hash();
	my %judge_panels;

	foreach my $panel (@{$panels}) {
		push @{$judge_panels{$panel->{judge}}}, $panel;
	}

	my $update_sth = $dbh->prepare(" update panel set flight = ? where id = ? ");

	foreach my $judge (sort keys %judge_panels) {

		my @panels = sort {
			$b->{ada_count} <=> $a->{ada_count}
			|| $b->{pref2} <=> $a->{pref2}
			|| $a->{pref1} <=> $a->{pref1}
			|| $b->{bracket} <=> $a->{bracket}
			|| $a->{letter} <=> $b->{letter}
		} @{$judge_panels{$judge}};

		if ($panels[0] && $panels[0]->{no_brackets}) {
			@panels = sort {
				$b->{ada_count} <=> $a->{ada_count}
				|| $b->{pref2} <=> $a->{pref2}
				|| $a->{pref1} <=> $a->{pref1}
				|| $a->{letter} <=> $b->{letter}
			} @panels;
		}

		my $counter = 1;

		foreach my $panel (@panels) {
			unless ($panel->{flight} == $counter) {
				$update_sth->execute($counter, $panel->{id});
			}
			$counter++;
		}
	}

	$sth->execute($round->id);

	my $log = Tab::ChangeLog->create({
		tag         => "tabbing",
		description => "Reset the section's flights",
		person      => $person,
		round       => $round,
	});

	my $msg = "Flights reset";

	if ($ARGS{return}) {
		return $msg;
	}

	$m->redirect("/panel/schemat/show.mhtml?round_id=".$round->id."&msg=$msg");

</%init>
