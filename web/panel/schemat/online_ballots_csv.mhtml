<%args>
	$dbh
	$tourn
	$person
	$round_id    => undef
	$timeslot_id => undef
</%args>
<%init>

	my $limit;
	my $label;

	if ($timeslot_id) {

		$limit = "and round.timeslot = ?";
		my $timeslot = Tab::Timeslot->retrieve($timeslot_id);
		$label = $timeslot->name."-Rounds";

	} elsif ($round_id) {

		$limit = "and round.id = ? ";
		my $round = Tab::Round->retrieve($round_id);
		$label = $round->label || "Round-".$round->name;
	}

	unless ($label) {
		$m->comp("/funclib/abort.mas",
			warning => "No valid rounds found. Hit Back and try again");
	}

	$label =~ s/\s+//g;
	my $filename = $label."-ScoresAndFeedback.csv";

	$m->clear_buffer;
	$r->content_type('application/csv');
	$r->headers_out->{'Content-Disposition'} = "attachment; filename=$filename";


	my $sth = $dbh->prepare("
		select
			score.id, score.tag score_tag, score.content score_content, score.speech score_speech,
			score.value score_value,
			ballot.id ballot_id,
			event.id event_id, event.abbr event_abbr,
			entry.id entry_id, entry.code entry_code,
			section.id section_id, section.letter section_letter,
			judge.id judge_id, judge.first judge_first, judge.last judge_last,
			(
				select room.name
				from room where section.room = room.id
			) as room_name

		from (ballot, panel section, judge, entry, event, round)

			left join score on score.ballot = ballot.id

		where 1=1
			$limit
			and section.round    = round.id
			and section.id       = ballot.panel
			and ballot.entry   = entry.id
			and ballot.judge   = judge.id
			and entry.event    = event.id
			and section.bye != 1
			and ballot.bye != 1
			and ballot.forfeit != 1
		order by section.id, judge.id, entry.id, score.tag
	");

	$sth->execute($timeslot_id || $round_id);

	my $results = $sth->fetchall_hash();
	my %ballots;
	my @scores = ('winloss', 'rank', 'point', 'rfd', 'comments', 'speech');

	$m->print("judge_id,");
	$m->print("judge_name,");
	$m->print("entry_id,");
	$m->print("entry_code,");
	$m->print("section_id,");
	$m->print("section_letter,");
	$m->print("room_name,");
	$m->print("event_id,");
	$m->print("event_abbr,");
	foreach my $score (@scores) {
		$m->print($score);
		$m->print(',');
	}
	$m->print("\n");

	foreach my $result (@{$results}) {

		unless ($ballots{$result->{ballot_id}}) {
			$ballots{$result->{ballot_id}} = {
				judge_id       => $result->{judge_id},
				judge_name     => $result->{judge_first}." ".$result->{judge_last},
				entry_id       => $result->{entry_id},
				entry_code     => $result->{entry_code},
				section_id     => $result->{section_id},
				section_letter => $result->{section_letter},
				room_name      => $result->{room_name},
				event_id       => $result->{event_id},
				event_abbr     => $result->{event_abbr},
			}
		}

		my $score_content = eval {
			return Tab::Utils::uncompress($result->{score_content});
		};

		$score_content =~ s/\"/\'/g;
		$ballots{$result->{ballot_id}}{$result->{score_tag}} = $score_content || $result->{score_value};
	}

	foreach my $ballot_id (sort keys %ballots) {

		my $ballot = $ballots{$ballot_id};

		$m->print('"'),
		$m->print($ballot->{judge_id});
		$m->print('","');
		$m->print($ballot->{judge_name});
		$m->print('","');
		$m->print($ballot->{entry_id});
		$m->print('","');
		$m->print($ballot->{entry_code});
		$m->print('","');
		$m->print($ballot->{section_id});
		$m->print('","');
		$m->print($ballot->{section_letter});
		$m->print('","');
		$m->print($ballot->{room_name});
		$m->print('","');
		$m->print($ballot->{event_id});
		$m->print('","');
		$m->print($ballot->{event_abbr});
		$m->print('","');

		foreach my $score (@scores) {
			$m->print($ballot->{$score});
			$m->print('","');
		}

		$m->print('"');
		$m->print("\n");
	}

	$m->abort();

</%init>
