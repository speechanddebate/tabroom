<%args>
	$dbh
	$tourn
	$round_id => undef
	$event_id => undef
</%args>
<%init>

	my $round = Tab::Round->retrieve($round_id) if $round_id;
	my $event = $round->event if $round;

	$event = Tab::Event->retrieve($event_id) unless $event;

	my $panels_sth = $dbh->prepare("
		select
			panel.id, panel.letter, room.name room
		from panel
			left join room on room.id = panel.room
		where panel.round = ?
		order by panel.letter
	");

	$panels_sth->execute($round->id);
	my $panels = $panels_sth->fetchall_hash();

	my %done;
	my %redo;
	my $max;

	foreach my $panel (@{$panels}) {
		if ($done{$panel->{letter}}++) {
			$redo{$panel->{id}}++;
		}
		$max = $panel->{letter} if $max lt $panel->{letter};
	}

	my $redo_letter = $dbh->prepare("
		update panel set letter = ? where id = ?
	");

	if (keys %redo) {

		foreach my $redo_id (sort {$a <=> $b} keys %redo) {
			++$max;
			$redo_letter->execute($max, $redo_id);
		}

		$panels_sth->execute($round->id);
		$panels = $panels_sth->fetchall_hash();
	}

	my $entries_sth = $dbh->prepare("
		select
			entry.id, entry.code, entry.name,
			school.id school_id, school.name school_name, school.code school_code,
			(
				select distinct(panel.letter)
				from panel, ballot
				where ballot.entry = entry.id
				and ballot.panel = panel.id
				and panel.round = round.id
				group by panel.id
			) as letter
		from (entry, round)
			left join school on school.id = entry.school
		where 1=1
			and entry.active = 1
			and entry.event = round.event
			and round.id = ?
		order by letter, entry.code
	");

	$entries_sth->execute($round->id);
	my $entries = $entries_sth->fetchall_hash();

</%init>

	<div class="main">

%		if ($round && $panels && scalar @{$panels}) {

			<span class="threequarters nospace">
				<h4>Manually assign <% $round->realname %> of <% $event->name %></h4>
			</span>

			<span class="quarter nospace rightalign" id="manual_buttonarea">
			</span>

			<& "/funclib/tablesorter.mas", table => "manual" &>

			<form
				action = "manual_speech_save.mhtml"
				method = "post"
			>
			<input
				type  = "hidden"
				name  = "round_id"
				value = "<% $round->id %>"
			>

			<table id="manual">

				<thead>
					<tr class="yellowrow">

						<th class="smallish">
							Code
						</th>

						<th class="smallish">
							Name
						</th>

						<th class="smallish">
							School
						</th>

						<th class="smallish">
							Section/Panel
						</th>

					</tr>
				</thead>

				<tbody>

%					foreach my $entry (@{$entries}) {

						<tr>
							<td class="smallish">
								<% $entry->{code} %>
							</td>

							<td class="smallish">
								<% $entry->{name} %>
							</td>

							<td class="smallish">
								<% $entry->{school_name} %>
							</td>

							<td class="limit5" data-text="<% $entry->{letter} %> || 0">
								<div class="nospace flexrow">
%								foreach my $panel (@{$panels}) {
									<span class="sixth grow">
										<label
											for="<% $entry->{id} %>_<% $panel->{id} %>"
											class="padleft"
										>
										<% $panel->{letter} %>
										<input type = "radio"
											id      = "<% $entry->{id} %>_<% $panel->{id} %>"
											name    = "<% $entry->{id} %>"
											value   = "<% $panel->{id} %>"
											<% $panel->{letter} eq $entry->{letter} ? "checked" : "" %>
										>
									</span>
%								}
								</div>
							</td>
						</tr>
%					}
				</tbody>
			</table>

			<div class="libl row rightalign">
				<span class="third centeralign">
					<input type="submit" value="Save Sections">
				</span>
			</div>

			</form>
%		}

	</div>

	<div class="menu">

		<div class="sidenote">

			<h4>Event:</h4>

			<form action="manual_speech.mhtml" method="post">

			<div class="row centeralign full">
				<select
					name     = "event_id"
					onChange = 'this.form.submit();'
					class    = "fixedmost"
				>
					<option value="">NONE</option>
%					foreach my $oevent ($tourn->events) {
%						next unless $oevent->type eq "congress" || $oevent->type eq "speech";
						<option
							value="<% $oevent->id %>"
							<% $event &&  $oevent->id == $event->id ? "selected" : "" %>
						><% $oevent->name %></option>
%					}
				</select>
			</div>

			</form>

%			if ($event) {

				<h4>Round</h4>

				<form action="manual_speech.mhtml" method="post">
					<input
						type  = "hidden"
						name  = "event_id"
						value = "<% $event->id %>"
					>

					<div class="row centeralign full">
						<select
							name     = "round_id"
							onChange = 'this.form.submit();'
							class    = "fixedmed"
						>
							<option value="">NONE</option>

%							foreach my $round ($event->rounds) {
								<option
									value="<% $round->id %>"
									<% $round->id == $round_id ? "selected" : "" %>
								><% $round->name %></option>
%							}
						</select>
					</div>
				</form>
%			}

%			if ($round) {

				<h4><% scalar @{$panels} %> Sections</h4>

				<form
					action = "create_panels.mhtml"
					method = "post"
				>

					<input
						type  = "hidden"
						name  = "round_id"
						value = "<% $round->id %>"
					>

					<input
						type  = "hidden"
						name  = "from"
						value = "manual_speech"
					>

					<div class="row">

						<span class="half semibold bluetext">
							Create Additional
						</span>

						<span class="quarter centeralign">
							<input
								type = "number"
								name = "number"
								min  = "0"
								max  = "99"
								size = "8"
								placeholder="#"
							>
						</span>

						<span class="quarter centeralign">
							<input type="submit" class="thin" value="Go">
						</span>

					</div>
				</form>
%			}

		</div>
	</div>
