<%args>
	$dbh
	$tourn
	$tourn_settings
	$entry_id => undef
	$round_id => undef
</%args>
<%init>

	my $round = Tab::Round->retrieve($round_id);
	my $entry = Tab::Entry->retrieve($entry_id);

	$m->abort unless $round;

	my $event = $round->event;
	my $school_id = $entry->school->id if $entry && $entry->school;
	my $region_id = $entry->school->region->id
		if $entry
		&& $entry->school
		&& $entry->school->region;

	my $rjf = $event->setting("region_judge_forbid");

	my $tz = $tourn->tz;
	$tz = "UTC" unless $tz;

	my %panels;
	my %dirty_judges;

	my $sth = $dbh->prepare('
		select
			panel.id panel_id, panel.letter,
			(select room.name from room
			where room.id = panel.room) room_name,
			ballot.speakerorder,
			CONVERT_TZ(ballot.judge_started, "+00:00", tourn.tz) started,
			entry.id entry_id, entry.code entry_code, entry.name entry_name,
			school.id school_id, school.code school_code,
			region.id region_id, region.code region_code,
			(select count(distinct ballot.panel)
				from ballot, ballot b2
				where ballot.entry = entry.id
				and ballot.panel = b2.panel
				and ballot.panel != panel.id
				and b2.entry = ?
			) as hits
		from (entry, ballot, panel, school, tourn)
			left join region on school.region = region.id

		where 1=1
			and panel.round = ?
			and panel.id = ballot.panel
			and ballot.entry = entry.id
			and entry.school = school.id
			and school.tourn = tourn.id
		group by entry.id
		order by panel.letter, ballot.speakerorder, entry.code
	');

	$sth->execute($entry->id, $round->id);
	my $entries = $sth->fetchall_hash();

	foreach my $entry (@{$entries}) {

		my $panel = $panels{$entry->{panel_id}};

		unless ($panel) {
			$panel = {
				letter => $entry->{letter},
				room   => $entry->{room_name},
				start  => substr($entry->{started}, 11, 5),
				score  => 0,
			}
		}

		push @{$panel->{entries}}, $entry;
		$panel->{size}++;

		if ($entry->{entry_id} == $entry_id) {
			$entry->{me}++;
			$panel->{mine}++;
		} else {

			if ($entry->{school_id} == $school_id) {
				$entry->{school_hit}++;
				$panel->{school_hits}++;
				$panel->{score} += 10000;
			}

			if ($region_id && $entry->{region_id} == $region_id) {
				$entry->{region_hit}++;
				$panel->{region_hits}++;
				$panel->{score} += 10;
				$panel->{score} += 9990 if $tourn_settings->{ncfl};
			}

			if ($entry->{hits} > 0) {
				$panel->{same_hits}++;
				$panel->{score} += 100 * $entry->{hits};
			}
		}

		$panels{$entry->{panel_id}} = $panel;
	}

	my $judge_sth = $dbh->prepare("
		select
			judge.id, judge.code, judge.first, judge.last,
			panel.id panel_id,
			judge.school school_id, school.name school_name,
			( select region.id from region, school where school.id = judge.school and region.id = school.region) region,
			( select count(ballot.id) from ballot where ballot.judge = judge.id and ballot.entry = entry.id ) ballots,
			( select strike.id from strike where strike.judge = judge.id and strike.entry = entry.id ) estrikes,
			( select strike.id from strike where strike.judge = judge.id and strike.school = ? ) sstrikes,
			( select strike.id from strike where strike.judge = judge.id and strike.region = ? ) rstrikes
		from (judge, entry, ballot, panel)
			left join school on school.id = judge.school
		where 1=1
			and entry.id    = ?
			and panel.round = ?
			and panel.id    = ballot.panel
			and ballot.judge = judge.id
		group by judge.id
	");

	$judge_sth->execute($school_id, $region_id, $entry->id, $round->id);
	my $judges = $judge_sth->fetchall_hash();

	foreach my $judge (@{$judges}) {

		my $panel = $panels{$judge->{panel_id}};
		push @{$panel->{judges}}, $judge;

		my $bad;

		if ($judge->{school_id} == $school_id) {
			$judge->{school_hit}++;
			$panel->{score} += 1000000;
			$bad++;
		}

		if ($judge->{estrikes}
			|| $judge->{sstrikes}
			|| $judge->{rstrikes}
		) {
			$judge->{strikes}++;
			$panel->{score} += 1000000;
			$bad++;
		}

		if ($judge->{region_id} == $region_id) {
			$judge->{region_hit}++;
			$panel->{score} += 10000;
			$panel->{score} += 990000 if $rjf;
			$bad++;
		}

		if ($judge->{ballots}) {
			$panel->{score} += 1000000 * $judge->{ballots};
			$bad++;
		}

		$panel->{bad_judges}++ if $bad;
		$panels{$judge->{panel_id}} = $panel;
	}

	my $code_style = $event->code_style;
	my $spansize = "seventh";

	$spansize = "fifth"
		if $code_style eq "names"
		|| $code_style eq "last_names"
		|| $code_style eq "names_lastfirst";

	$spansize = "third"
		if $code_style eq "school_names"
		|| $code_style eq "school_first_names"
		|| $code_style eq "school_last_names"
		|| $code_style eq "code_name";

</%init>

	<div class="menu">

		<div class="sidenote">

			<h4>Navigation</h4>

				<a
					class="blue full nowrap"
					href="/panel/schemat/show.mhtml?round_id=<% $round->id %>&show=yes">
					<% $round->realname %> <% $event->abbr %> Schemat
				</a>

%				if ($entry) {

					<a class="blue full nowrap"
						href="/register/entry/edit.mhtml?entry_id=<% $entry->id %>">
						<% $entry->code %> <% $entry->name %> info
					</a>

%					my $warn = "This will delete any scores or ballots this entry has in this round.   Are you sure?";

					<a class="dkred full martop nowrap"
						<& "/funclib/confirm.mas", warn => $warn &>
						href="entry_rm.mhtml?round_id=<% $round->id %>&entry_id=<% $entry->id %>"
					>
						Remove <% $entry->code %> from round
					</a>
%				}

		</div>

		<div class="sidenote">

%			if ($entry) {
				<h4>Entry Details</h4>

					<div class="row ">
						<span class="quarter">
							Code
						</span>
						<span class="threequarter">
							<% $entry->code %>
						</span>
					</div>

					<div class="row ">
						<span class="quarter">
							Name
						</span>
						<span class="threequarter">
							<% $entry->name %>
						</span>
					</div>

					<div class="row ">
						<span class="quarter">
							School
						</span>
						<span class="threequarter">
							<% $entry->school ? $entry->school->short_name : "NO SCHOOL" %>
						</span>
					</div>

%					if ($tourn_settings->{ncfl}) {
						<div class="row ">
							<span class="quarter">
								Diocese
							</span>
							<span class="threequarter">
								<% $entry->school->region ? $entry->school->region->name : "NO REGION" %>
							</span>
						</div>
%					}
%			}

			<h4 class="martopmore">Move a different entry:</h4>

			<form action="speech_round_edit.mhtml" method="post">

			<input
				type  = "hidden"
				name  = "round_id"
				value = "<% $round->id %>"
			>

			<div class="padvert row centeralign">
				<select
					name     = "entry_id"
					class    = "fixedmed"
					onchange = 'this.form.submit();'
				>
%					foreach my $entry ($event->entries( active => 1 )) {
						<option
							value="<% $entry->id %>"
							<% $entry->id == $entry_id ? 'selected="selected"' : "" %>
						><% $entry->code %> <% $entry->name %></option>
%					}
				</select>

			</div>

			<label for="add">
				<div class="row hover">
					<span class="fourfifths semibold redtext centeralign">
						Add entry 2x instead of moving
					</span>

					<span class="fifth centeralign">
						<input
							type     = "checkbox"
							id       = "add"
							name     = "add"
							onChange = "this.form.submit();"
							value    = 1
							<% $ARGS{"add"} ? 'checked' : "" %>
						>
					</span>
				</div>
			</label>

			</form>

		</div>

		<div class="sidenote">

			<h4>Add More Sections</h4>

			<div class="row padless">

				<form action="create_panels.mhtml" method="post">

				<input
					type  = "hidden"
					name  = "round_id"
					value = "<% $round->id %>"
				>

				<input
					type  = "hidden"
					name  = "entry_id"
					value = "<% $entry_id %>"
				>

				<span class="smallish quarter padless">
					Number
				</span>

				<span class="half padless">
					<input
						class = "notfirst thin"
						type  = "number"
						size  = "3"
						min   = "0"
						max   = "999"
						name  = "number"
					>
				</span>

				<span class="smallish padless">
					<input
						type  = "submit"
						value = "Go"
						class = "notfirst thin"
					>
					</form>
				</span>
			</div>
		</div>
	</div>

	<div class="main">

		<& /funclib/tablesorter.mas, table => "speechmove", nobuttons => 1 &>

		<div class="full nospace flexrow">
%			if ($entry) {
				<span class="half nospace">
					<h4><% $ARGS{"add"} ? "Add" : "Move" %> entry <% $entry->code %> </h4>
				</span>

				<span class="half rightalign nospace">
					<h5><% $entry->name %> </h5>
				</span>
%			} else {
				<span class="half nospace">
					<h4>Manually move an entry</h4>
				</span>
%			}

		</div>

		<div class="flexrow">

%		if ($ARGS{"add"}) {

			<span class="half semibold redtext nospace">
				Hit the green plus to add Entry <% $entry->code %> to that section
			</span>

			<span class="half semibold redtext nospace rightalign">
				Speaker WILL NOT be removed from their current section
			</span>

%		} elsif ($entry) {

			<span class="half semibold bluetext">
				<p>Click "add" at right to move <% $entry->code %> to that room.</p>
			</span>

			<span class="half semibold bluetext rightalign">
				<p>Click another speaker code to move that entry instead. </p>
			</span>
%		}

		</div>

		<table id="speechmove">

			<thead>

				<tr class="yellowrow">

					<th class="smallish limittiny">
						Room
					</th>

					<th class="smallish limit">
						Judges
					</th>

					<th class="smallish">
						Entries
					</th>

					<th class="smallish limittiny">
						#
					</th>

					<th class="smallish limittiny" title="Number of Judging Issues">
						J
					</th>

					<th class="smallish limittiny" title="Number of Repeat Entry Hits">
						H
					</th>

					<th class="smallish limittiny" title="Number of School Hits">
						S
					</th>

%					if ($region_id) {
						<th class="smallish limittiny" title="Number of Region Hits">
							<% $tourn_settings->{ncfl} ? "D" : "R" %>
						</th>
%					}

					<th class="smallish" title="Did the judges hit start?">
						Start
					</th>

					<th class="smallish limittiny">
						Pick
					</th>

				</tr>

			</thead>

			<tbody>

<%perl>
				foreach my $panel_id (sort {
					$panels{$a}{score} <=> $panels{$b}{score}
					|| $panels{$a}{size} <=> $panels{$b}{size}
				} keys %panels) {

					my $panel = $panels{$panel_id};
</%perl>
					<tr>

						<td class="smallish">
							<a
								class="white"
								href="/panel/schemat/panel_view.mhtml?panel_id=<% $panel_id %>"
							>
								<% $panel->{room} || "None" %>
							</a>
						</td>

						<td class="smallish nospace">
%							foreach my $judge (@{$panel->{judges}}) {
								<a class="full marno nowrap padvertless padleft padright white hover
<%perl>
									my $title;
									if ($judge->{school_hit}) {
										$m->print("redtext semibold");
										$title = "Same School";
									} elsif ($judge->{strikes}) {
										$m->print("redtext semibold");
										$title = "Strike/Constraint";
									} elsif ($judge->{ballots}) {
										$m->print("orangetext semibold");
										$title = "Judged Before ".$judge->{ballots}."x ";
									} elsif ($judge->{region_hit}) {
										$m->print("yellowtext semibold");
										$title = "Same Region";
									}
</%perl>
"
									href="/register/judge/edit.mhtml?judge_id=<% $judge->{id} %>"
									title="<% $title %>  <% $judge->{school_name} || "Unaffiliated" %>"
								>
									<% $judge->{code} %> <% $judge->{first}." ".$judge->{last} %>
								</a>
%							}
						</td>

						<td class="smallish padless">

%							foreach my $entry (@{$panel->{entries}}) {
								<a
									class="nowrap border blacktext <% $spansize %> marno padvert odd hover centeralign
<%perl>
									my $title;
									if ($entry->{me}) {
										$m->print("dkblue whitetext");
										$title = "ENTRY YOU ARE MOVING!"
									} elsif ($entry->{school_hit}) {
										$m->print("dkred whitetext");
										$title = "Same School"
									} elsif ($entry->{hits}) {
										$m->print("dkgrey whitetext");
										$title = "Hit before ".$entry->{hits}."x";
									} elsif ($entry->{region_hit}) {
										$m->print("dkorange whitetext");
										$title = "Same Region/Dio"
									}
</%perl>
"
									title = "<% $title %>"
									href="/panel/manipulate/entry_edit.mhtml?entry_id=<% $entry->{id} %>&round_id=<% $round->id %>&add=<% $ARGS{"add"} %>"
								>
									<% $entry->{entry_code} %>
								</a>
%							}
						</td>

						<td class="smallish centeralign">
							<% $panel->{size} %>
						</td>

						<td class="smallish centeralign">
							<% $panel->{bad_judges} %>
						</td>

						<td class="smallish centeralign">
							<% $panel->{same_hits} %>
						</td>

						<td class="smallish centeralign">
							<% $panel->{school_hits} %>
						</td>

%						if ($region_id) {
							<td class="smallish centeralign">
								<% $panel->{region_hits} %>
							</td>
%						}

						<td class="smallish centeralign nospace">
							<% $panel->{start} || "No" %>
						</td>

						<td class="smallish centeralign nospace">

%							unless ($panel->{bad_judges} || $panel->{mine} || (not defined $entry)) {
								<a
									class="buttonwhite greentext smallish half fa fa-lg fa-plus invert"
									href="entry_move.mhtml?entry_id=<% $entry->id %>&panel_id=<% $panel_id %>&add=<% $ARGS{'add'} %>"></a>
%							} else {
								Judge Block
%							}

						</td>

					</tr>

%				}

			</tbody>

		</table>

%		if ($entry) {
			<div class="full nospace martopmore centeralign">
				<p class="redtext semibold">
					Red entries/judges are from the same school as <% $entry->code %>
				</p>

				<p class="orangetext semibold">
					Orange entries/judges have previously hit <% $entry->code %>
				</p>

				<p class="bluetext semibold">
					The blue entry is <% $entry->code %>
				</p>
			</div>
%		}

	</div>
