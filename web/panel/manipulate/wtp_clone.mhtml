<%args>
	$person
	$session
	$round_id
	$dbh
</%args>
<%init>

	my $round = Tab::Round->retrieve($round_id);

	my $round_name = $round->label;
	$round_name =~ s/\d//g;

	my $section_sth = $dbh->prepare('
		select
			section.letter, ballot.id, ballot.speakerorder, ballot.entry,
			section.room
		from panel section, ballot
		where 1=1
			and section.round = ?
			and section.id = ballot.panel
		group by ballot.entry
	');

	$section_sth->execute($round->id);
	my $sections = $section_sth->fetchall_hash();

	my $count_sth = $dbh->prepare("
		select
			section.letter, count(distinct ballot.entry) count
		from panel section, ballot
		where 1=1
			and section.round = ?
			and section.id = ballot.panel
		group by section.letter
	");

	$count_sth->execute($round->id);
	my $counteds = $count_sth->fetchall_hash();
	my %counts = map {$_->{letter} => $_->{count}} @{$counteds};

	my $round_sth = $dbh->prepare('
		select
			round.id, round.name, round.label, round.type
		from round
		where 1=1
			and round.event = ?
			and round.label LIKE "'.$round_name.'%"
			and round.id != ?
			order by round.label
	');

	$round_sth->execute($round->event, $round->id);
	my $rounds = $round_sth->fetchall_hash();
	my $offset = 1;

	foreach my $round (@{$rounds}) {

		my %ns = ();

		foreach my $section (@{$sections}) {

			unless ($ns{$section->{letter}}) {

				$ns{$section->{letter}} = Tab::Panel->create({
					round  => $round->{id},
					letter => $section->{letter},
					flight => 1,
				});
			}

			my $order = $section->{speakerorder};
			$order += $offset;

			if ($order > $counts{$section->{letter}}) {
				$order -= $counts{$section->{letter}};
			}

			Tab::Ballot->create({
				panel        => $ns{$section->{letter}},
				speakerorder => $order,
				entry        => $section->{entry},
			});
		}

		$offset++;
	}

	my $msg = "Sections shuffled into all the $round_name rounds.";
	$m->redirect('/panel/schemat/show.mhtml?round_id='.$round->id."&msg=$msg");

</%init>

