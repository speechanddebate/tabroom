<%args>
</%args>
<%init>

	my $dbh = Tab::DBI->db_Main();

	my $sth = $dbh->prepare("
		select
			entry.id
		from entry, event, event_setting supp

		where event.tourn = ?
			and event.id = supp.event
			and supp.tag = 'supp'
			and event.id = entry.event
			and entry.active = 1

		and NOT EXISTS (
			select es.id
				from entry_setting es
			where es.id
				and es.tag   = 'reregistered'
				and es.entry = entry.id
		)

	");

	$sth->execute(37602);
	my $refs = $sth->fetchall_hash();

	my $rereg_sth = $dbh->prepare("insert into entry_setting (entry, tag, value, value_text) values (?, ?, ?, ?)");

	foreach my $ref (@{$refs}) {
		$rereg_sth->execute($ref->{id}, 'reregistered', 1, '');
		$rereg_sth->execute($ref->{id}, 'supp_log', 'text', '<p>Re-registered automatically as a Supp only competitor</p>');
	}

	$m->print("Fin");


</%init>
