<%args>
	$dbh
	$tourn
	$person
	$value => 0
</%args>
<%init>

	$m->clear_buffer();
	$r->content_type('application/json');

	my $sth = $dbh->prepare("update result_set set published = ? where tourn = ?");
	$sth->execute($value, $tourn);

	my $file_sth = $dbh->prepare("update file set published = ? where tourn = ? and tag = 'result' ");
	$file_sth->execute($value, $tourn);

	my %response = (
		error   => "false",
		message => "All results sets and file uploads have been published"
	);

	$m->print(JSON::encode_json(\%response));
	$m->abort();

</%init>
