<%args>
	$person
	$perms
	$dbh
	$result_set_id => undef
</%args>
<%init>

	$m->clear_buffer();
	$r->content_type('application/json');
	my $set = Tab::ResultSet->retrieve($result_set_id);

	unless ($set && $set->id) {

		my $response = {
			error   => \1,
			destroy => $result_set_id,
			message => "Set does not exist",
		};

		$m->print(JSON::encode_json($response));
		$m->abort();
	}

	my $msg = "Result set ".$set->label." in ".$set->event->abbr." deleted" if $set->event;
	$msg = "Result set ".$set->label." in ".$set->tourn->name." deleted" if $set->tourn;

	my $sth = $dbh->prepare(" delete rs.* from result_set rs where rs.id = ? ");
	$sth->execute($set->id);

	my $response = {
		error   => \0,
		destroy => $result_set_id,
		message => $msg,
	};

	$m->print(JSON::encode_json($response));
	$m->abort();

</%init>

