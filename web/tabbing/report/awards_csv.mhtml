<%args>
	$dbh
	$tourn
	$perms
	$tourn_settings
	$event_id
</%args>
<%init>

	my %events = $m->comp("/funclib/perms/events.mas",
		tourn        => $tourn,
		perms        => $perms,
		limited      => 1,
		no_attendees => 1
	);

	my @event_ids;

	Tab::debuglog("Event $event_id");

	if ($event_id && (not defined $events{$event_id})) {
		$m->comp("/funclib/abort.mas", message => "You are not authorized to report that event.");
	} elsif ($event_id) {
		push @event_ids, $event_id;
	} else {
		@event_ids = keys %events;
	}

	my @rows;

	my $header = [
		'Entry Code',
		'Entry Name',
		'Student Names',
		'School',
		'State',
		'Region',
		'RegCode',
		'Placement',
		'Rank',
		'Coaching',
		'Piece Title'
	];

	my $limit;
	if ($ARGS{cutoff}) {
		$limit = " limit ".int($ARGS{cutoff});
	}

	my $result_sth = $dbh->prepare("
		select
			result.rank, result.place,
			entry.id, entry.code, entry.name,
			GROUP_CONCAT( CONCAT(student.first,' ',student.last) SEPARATOR ', ') names,
			school.name school_name, chapter.formal, chapter.state,
			region.code region_code, region.name region_name,

			(
				select title.value
				from entry_setting title
				where title.entry = entry.id
				and title.tag = 'title'
			) as title,

			(
				select coaches.value
				from entry_setting coaches
				where coaches.entry = entry.id
				and coaches.tag = 'coach_script'
			) as coaches

		from (result_set, result, entry, entry_student es, student)
			left join school on school.id = entry.school
			left join region on region.id = school.region
			left join chapter on chapter.id = school.chapter
		where 1=1

			and result_set.event = ?
			and (result_set.tag = 'final' OR result_set.label = 'Final Places')
			and result_set.id = result.result_set
			and result.entry = entry.id
			and entry.id = es.entry
			and es.student = student.id
		group by entry.id
		order by result.rank
		$limit
	");

	foreach my $event_id (sort {
			$events{$a}{"type"} cmp $events{$b}{"type"}
			|| $events{$a}{"name"} cmp $events{$b}{"name"}
		} @event_ids
	) {

		my $event = $events{$event_id};
		push @rows, [ $events{$event_id}{'name'}, $events{$event_id}{'abbr'} ];
		push @rows, $header;

		$result_sth->execute($event_id);
		my $results = $result_sth->fetchall_hash();

		foreach my $ref (@{$results}) {
			push @rows, [
				$ref->{code},
				$ref->{name},
				$ref->{names},
				($ref->{formal} || $ref->{school_name}),
				$ref->{state},
				$ref->{region_name},
				$ref->{region_code},
				$ref->{place},
				$ref->{rank},
				$ref->{coaches},
				$ref->{title}
			];
		}
	}

    my $filename = "AwardsReport-AllEvents.csv";
	if ($event_id) {
    	$filename = "AwardsReport-".$events{$event_id}{abbr}.".csv";
	}

	$m->clear_buffer();
    $r->content_type('application/csv');
    $r->headers_out->{'Content-Disposition'} = "attachment; filename=$filename";

	foreach my $row (@rows) {
		foreach my $val (@{$row}) {
			$m->print('"');
			$m->print($val);
			$m->print('",');
		}
		$m->print("\n");
	}

	$m->abort();

</%init>
