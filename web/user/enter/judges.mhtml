					</span>
				</div>

%				my $counter = 1;

%				foreach my $judge ($school->judges( category => $category->id)) {

					<div class='row padvertless' id="<% $judge->id %>">
						<span class="twentieth padleft">
							<% $counter++ %>
						</span>

						<span class="fifth">
							<input
								type        = "text"
								name        = "first_<% $judge->id %>"
