%				if (scalar (keys %{$cat_warnings}) > 0) {
%					my $notfirst;

					<div class="centeralign">
						<span class='ninetenths'>
%						foreach my $category (sort {$a cmp $b} keys %{$cat_warnings}) {
%							unless ($notfirst++) {
								<h5 class="warning">Warning: You have judges that do not cover entries</h5>
