				</a>


				<a
					class="yellow full semibold"
					href="/user/chapter/judge_edit.mhtml?from=<% $category->id %>&chapter_id=<% $school->chapter->id %>">
					Add New Judge to Roster
				</a>

				<div class="centeralign redtext semibold padvert">
					<% $category->abbr %>
					judges due by <& '/funclib/showdt.mas',
						dt     => $category_deadline || $judge_deadline,
						tz     => $person->tz,
						showtz => 1,
						at     => 1,
						format => "murica_short"
					&>
				</div>

%			} elsif ($deadline) {

				<div class="centeralign redtext semibold padvert">
					Judge deadline was <% Tab::xmldt($category_deadline) %>
				</div>

%			} elsif ($category) {
				<p>
					You have no judges on your roster to add.  Please add
					them before registering them into the tournament.  You
					only need to type in each judge's name to your roster
					once; they'll be available for all future tournaments.
				</p>

				<a
					class="yellow full martopmore semibold"
					href="/user/chapter/judge_edit.mhtml?from=<% $category->id %>&chapter_id=<% $school->chapter->id %>">
					Add Judge to Roster
				</a>
%			}

%			if ($tourn_settings{"ncfl"} || $tourn_settings{"mock_trial_registration"}) {

%			} else {

				<h4 class="padbottom">
					Judge Categories
				</h4>
<%perl>
				foreach my $ocategory (@categories) {

					my %status;
					my $ocategory_deadline;
					my %ocategory_settings = %{$cat_settings{$ocategory->id}};

					if ($tourn_settings{"ncfl"}) {

						$status{"unc"} = scalar ($school->judges(category => $ocategory->id));

					} else {

						my $weekend_id = $ocategory->setting('weekend');

						next if $weekend_id eq "nope";

						next if $weekend_id
							&& $weekends{$weekend_id}{"reg_start"} > $now;

						$ocategory_deadline = $ocategory_settings{"deadline"};
						my $no_free = $ocategory_settings{"free_strikes_dont_count"};

						$ocategory_deadline->set_time_zone($tz) if $ocategory_deadline;

						($status{"unc"}, $status{"over"}) = $m->comp(
							"/funclib/judgemath/uncovered_burden_by_category.mas",
								school            => $school,
								category_settings => \%ocategory_settings,
								tourn_settings    => \%tourn_settings,
								category          => $ocategory
						);

						@{$status{"category_judges"}} = $school->judges(category => $ocategory->id);

						$status{obligation} = $obligations{$ocategory->id};

						my %stimes_under = $m->comp(
							"/funclib/judgemath/judge_partials_short.mas",
							category          => $ocategory,
							category_settings => \%ocategory_settings,
							tourn_settings    => \%tourn_settings,
							school            => $school
						);

						my $partial_under;

						foreach my $key (keys %stimes_under) {
							$partial_under += $stimes_under{$key};
						}

						my $rounds;

						if ($ocategory_settings{rounds_per}) {
							foreach my $judge (@{$status{"category_judges"}}) {
								$status{"rounds"} += $judge->obligation
									unless $no_free && $judge->setting("free_strike");
							}
						}

						$status{"line_color"} = "odd";

						if ($status{"unc"} > 0) {

							$status{"status_mark"} = "fa fa-lg fa-times-circle redtext";
							$status{"text"}        = "redtext";
							$status{"title"}       = "You have not met obligation in this judge category";

						} elsif ($partial_under > 0) {

							$status{"status_mark"} = "fa redtext fa-exclamation-triangle";
							$status{"text"}        = "redtext";
							$status{"title"}       = "You are short of obligation in some time blocks in this category";

						} else {

							$status{"status_mark"} = "fa fa-check-circle greentext";
							$status{"title"}       = "Obligation met";
							if (scalar @{$status{"category_judges"}} > 0) {
								$status{"text"} = "bluetext";
							}

						}

						if ($ocategory == $category) {
							$status{"line_color"} = "even";
						}
					}

					my $jpool_status;

					if ($registrant_jpools) {
						foreach my $jpool_id (sort keys %{$registrant_jpools}) {
							if ($jpools->{$jpool_id}{'category'} == $ocategory->id && $jpools->{$jpool_id}{'under'} > 0) {
								$jpool_status .= "You need to enter ".$jpools->{$jpool_id}{"under"}." more judges into ";
								$jpool_status .= $jpools->{$jpool_id}{"name"}."\n";
								$status{"status_mark"} = "fa redtext fa-exclamation-triangle";
								$status{"text"}        = "redtext";
							}
						}
					}

					if ($jpool_status) {
						$status{"title"} = $jpool_status;
					}

					my $name = $ocategory->name;
					$name =~ s/\(/<span class='full smallish graytext padright'>/g;
					$name =~ s/\)/<\/span>/g;
</%perl>
					<a
						class = "<% $status{"line_color"} %> full grayhover white marno ltborderbottom flexrow"
						href  = "judges.mhtml?school_id=<% $school->id %>&category_id=<% $ocategory->id %>"
						title = "<% $status{"title"} %>"
					>

						<span
							class="nowrap threefifths semibold biggish <% $status{"text"} %> padrightmore"
						>
							<% $name %>
						</span>

						<span class="threetenths nospace semibold <% $status{"text"} %> padleftmore grow">

%							if ($status{"obligation"}) {

								<% $status{"rounds"}
									? $status{"rounds"}
									: scalar @{$status{"category_judges"}} %>/<% $status{"obligation"}
								%>

								<% $status{"rounds"}
									?
										( $status{"unc"} < 1
										  && ($status{"rounds"} && $status{"rounds"} < $status{"obligation"})
										)
											? "+ ".$exchange_hires." rounds"
											: ""
									: ($status{"unc"} < 1
										&& $status{"obligation"} > 0
										&& (scalar @{$status{"category_judges"}} < $status{"obligation"})
									)
										? "+ ".$exchange_hires." hires"
										: ""
									%>

%							} elsif ($jpool_status) {

								<span class="orangetext">
									<% $jpool_status %>
								</span>

%							} elsif ($status{"over"}) {

								<span class="orangetext">
<%perl>
								if ($ocategory_settings{"uncovered_entry_fee"} > 0
									&& $ocategory_settings{judge_per}
								) {
</%perl>
									<% $status{"over"} %> extra entr<% ($status{"over"} == 1) ? "y" : "ies" %>
%								} elsif ($ocategory_settings{judge_per}) {
									<% ceil ($status{"over"} / $ocategory_settings{judge_per}) %> extra
%								} elsif ($ocategory_settings{rounds_per}) {
									<% $status{"over"} %> extra round<% ($status{"over"} == 1) ? "" : "s" %>
%								}
								</span>
%								if (@requests) {
									<br />
									You may still be charged for undeleted hired requests, even if you provide extra judges.
%								}

%							} else {
%								if (scalar @{$status{"category_judges"}}) {
									<% scalar @{$status{"category_judges"}} || 0 %>/<% $status{"unc"} %>
%								} else {
									<% $status{"unc"} %>
%								}
%							}
						</span>

						<span class="tenth centeralign <% $status{"status_mark"} %>">
						</span>
					</a>

%					if ($ocategory_deadline) {

						<a
							href  = "/user/tourn/entry/judges.mhtml?school_id=<% $school->id %>&category_id=<% $ocategory->id %>"
							class = "white italic centeralign full"
						>
							* <% $ocategory->abbr %>
							Judges due:
							<& "/funclib/showdt.mas",
								dt     => $ocategory_deadline,
								tz     => $tz,
								format => "murica_short"
							&>
						</a>

%					}
%				}
%			}

		</div>
	</div>
