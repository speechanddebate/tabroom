						<input
							type  = "submit"
							value = "Add Judge"
						>
					</span>
				</div>

				</form>

				<a
					class="blue full martopmore"
					href="judges_eligible.mhtml?category_id=<% $category->id %>&school_id=<% $school->id %>">
