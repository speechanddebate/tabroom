<%args>
	$person
	$school
</%args>
<%init>

	my $tourn = $school->tourn;
	my %tourn_settings = $tourn->all_settings();
	my $year = $tourn->start->year;

</%init>

	<div class="main">

		<h2><% $tourn->name %></h2>

		<h5>Notes/Disclaimer</h5>

%		if ($tourn_settings{"nsda_district"}) {
			<p class="semibold">
				The coach(es) of all schools attending districts to qualify for
				the National tournament must agree to the following statement:
			</p>
%		}

		<script>

			function checkAllTheseDisclaimers() {
				$(`#submission_button`).addClass('hidden');
				$(`#submission_message`).removeClass('hidden');
				let notOK = false;

				$(`.disclaimers`).each( (index, item) => {
					if ( !$(item).is(':checked')) {
						notOK = true;
					}
				});

				if (!notOK) {  // I'm not not okay too, tabroom.
					$(`#submission_button`).removeClass('hidden');
					$(`#submission_message`).addClass('hidden');
				}
			}

		</script>

		<div class="padleftmore padrightmore padtop borderredthin martopmore bluetext semibold">
			<% $tourn_settings{"disclaimer"} %>
		</div>

		<div class='centeralign padvert'>
			<label
				for   = "disclaimer"
				class = "yellowhover padtop padbottom padleftmore padrightmore"
			>
				<span class="inline padright semibold italic">
					I have read and agree to the above
				</span>
				<input
					id       = "disclaimer"
					class    = "disclaimers marbottom"
					type     = "checkbox"
					onChange = "checkAllTheseDisclaimers();"
				>
			</label>
		</div>

%		if ($tourn_settings{"tedious_second_disclaimer"}) {
			<div class="padleftmore padrightmore padtop borderredthin martopmore bluetext semibold">
				<% $tourn_settings{"tedious_second_disclaimer"} %>
			</div>

			<div class='centeralign padvert'>
				<label
					for   = "tedious_second_disclaimer"
					class = "yellowhover padtop padbottom padleftmore padrightmore"
				>
					<span class="inline padright semibold italic">
						I have read and agree to the above
					</span>
					<input
						id       = "tedious_second_disclaimer"
						class    = "disclaimers"
						type     = "checkbox"
						onChange = "checkAllTheseDisclaimers();"
					>
				</span>
			</div>
%		}

%		if ($tourn_settings{"refund_information"}) {

			<h5 class="martopmore">
				Information for refunds of bonds and overpayments:
			</h5>

			<form
				action = "refund_save.mhtml"
				method = "post"
			>

			<input
				type  = "hidden"
				name  = "school_id"
				value = "<% $school->id %>"
			>

%			if ($tourn_settings{"enable_credit"}) {

				<div class="ltyellow row martopmore">
					<span class="third semibold">
						Preferred refund method:
					</span>

					<span class="twothirds semibold">
						<label for="credit">
							<span class="half hover">
								<input
									type     = "radio"
									name     = "refund_method"
									id       = "credit"
									value    = "credit"
									onChange = "toggleRefund('credit');"
									checked  = 1
								> Credit towards <% $year + 1 %>
							</span>
						</label>

						<label for="check">
							<span class="half hover">
								<input
									type     = "radio"
									name     = "refund_method"
									id       = "check"
									value    = "check"
%									unless ($tourn_settings{"enable_credit"}) {
										checked  = 1
%									}
									onChange = "toggleRefund('check');"
								> Check
							</span>
						</label>
					</span>
				</div>
%			}

			<div
				class="refundcredit centeralign toggle padvertmuchmore"
			>
				<span class="fourfifths leftalign bigger">
					<% $tourn_settings{"judgebond_message"} %>
				</span>
			</div>

			<span class="refundcheck hidden toggle full">

				<div class="row padvert">
					<span class="third semibold bluetext">
						Make refund checks payable to:
					</span>

					<span class="twothirds">
						<input
							type  = "text"
							name  = "refund_payable"
							size  = "64"
							value = "<% $school->setting('refund_payable') %>"
						>
					</span>
				</div>

				<div class="row">
					<span class="third semibold bluetext">
						Address to send refund checks
					</span>

%					my $default_address = $school->setting('refund_address');

					<span class="twothirds">
						<& "/funclib/address.mas",
							tag      => "refund",
							person   => $person,
							default  => $default_address
						&>
					</span>
				</div>

			</span>

			<div class="liblrow rightalign">
				<span
					class = "centeralign redtext full semibold padtopmore"
					id    = "submission_message"
				>
					You must agree to all the disclaimers above before you may proceed.
				</span>

				<span class="half centeralign">
					<input
						class = "hidden"
						id    = "submission_button"
						type  = "submit"
						value = "Save Refund Information <%
							$tourn_settings{"disclaimer"}
							? "And Agree to Disclaimer"
							: "" %>"
					>
				</span>
			</div>

%		} elsif ($tourn_settings{"instruction_url"}) {

			<div class="full row padmore martopmore rightalign">
				<span
					class = "centeralign redtext full semibold"
					id    = "submission_message"
				>
					You must agree to all the disclaimers above before you may proceed.
				</span>

				<span class="third centeralign">
					<a
						id    = "submission_button"
						class = "buttonwhite bluetext hover invert hidden"
						href  = "instructions.mhtml?school_id=<% $school->id %>&disclaimed=1"
					>
						I understand and agree
					</a>
				</span>
			</div>


%		} elsif ($tourn_settings{"nsda_district"}) {

			<div class="full row padmore martopmore rightalign">
				<span
					class = "centeralign redtext full semibold"
					id    = "submission_message"
				>
					You must agree to all the disclaimers above before you may proceed.
				</span>

				<span class="third centeralign">
					<a
						id    = "submission_button"
						class = "buttonwhite bluetext hover invert"
						href  = "nsda_roster_check.mhtml?school_id=<% $school->id %>&disclaimed=1"
					>
						I understand and agree
					</a>
				</span>
			</div>

%		} else {

			<div class="full row padmore martopmore rightalign">
				<span
					class = "centeralign redtext full semibold"
					id    = "submission_message"
				>
					You must agree to all the disclaimers above before you may proceed.
				</span>

				<span class="third centeralign">
					<a
						id    = "submission_button"
						class = "buttonwhite bluetext hover invert"
						href  = "entry.mhtml?school_id=<% $school->id %>&disclaimed=<% $person %>"
					>
						I understand and agree
					</a>
				</span>
			</div>
%		}

	</div>

	<script>

		function toggleRefund(thing) {
			$(".toggle").addClass("hidden");
			$(".refund"+thing).removeClass("hidden");
			fixVisual();
		}

%		unless ($tourn_settings{"enable_credit"}) {
			$(document).ready(function() {
				toggleRefund('check');
			});
%		}

	</script>

