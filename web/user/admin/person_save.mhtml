<%args>
	$edit_id
	$first
	$last
	$email
	$middle         => undef
	$pronoun        => undef
	$phone          => undef
	$street         => undef
	$city           => undef
	$state          => undef
	$country        => undef
	$no_email       => 0
	$zip            => undef
	$site_admin     => undef
	$nsda_admin     => 0
	$naudl_admin    => 0
	$banned         => 0
	$timezone       => undef
	$nsda           => undef
	$api_key        => undef
	$person
	$dbh
</%args>
<%init>

	use Email::Valid;

	$phone  =~ s/\D//g;
	$email  =~ s/\s+//g;
	$email = lc($email);
	my $msg;

	my $pre_clear_sth = $dbh->prepare("
		delete ps.*
			from person_setting ps
		where ps.person = ?
			and (ps.value_text = '' OR ps.value_text IS NULL)
			and (ps.value_date = '' OR ps.value_date IS NULL)
			and (ps.value = '' OR ps.value IS NULL)
	");

	$pre_clear_sth->execute($edit_id);

	my $emailok = Email::Valid->address(
		-address => $email,
		-mxcheck => 1
	) ? 'yes' : 'no';

	unless ($emailok eq "yes") {
		my $err = "That email address is not valid.  Please enter a valid address. $emailok";
		$m->redirect("person_edit.mhtml?edit_id=$edit_id&err=$err");
	}

	my $edit = Tab::Person->retrieve($edit_id);

	if ($email ne lc($edit->email)) {

		my $existing = Tab::Person->search( email => $email)->first;

		if ($existing) {
			my $err = "Email address $email already has an account belonging to: ";
			$err   .= $existing->first." ".$existing->last." (".$existing->email.") ";
			$m->redirect("/user/admin/person_edit.mhtml?err=$err");
		}
	}

	$edit->first($first);
	$edit->middle($middle);
	$edit->pronoun($pronoun);
	$edit->last($last);
	$edit->street($street);
	$edit->city($city);
	$edit->email($email);
	$edit->state($state);
	$edit->country($country);
	$edit->no_email($no_email);
	$edit->zip($zip);
	$edit->site_admin($site_admin);
	$edit->phone($phone || 0);
	$edit->tz($timezone);
	$edit->update();

	my %edit_settings = $edit->all_settings();

	$api_key =~ s/[\W_]//g;
	undef $api_key if $api_key < 1;

	my $ban_message;
	my $subject;

	foreach my $tag (
		"nsda_admin",
		"nsda_email",
		"nsda_id",
		"naudl_admin",
		"ban_reason",
		"email_unconfirmed",
		"email_confirmation_key",
		"api_key"
	) {

		if ($ARGS{$tag} eq "0" || $ARGS{$tag} eq "") {
			undef($ARGS{$tag});
		}

		if (
			$edit_settings{$tag}
			&& (not defined $ARGS{$tag})
		) {

			$edit->setting($tag, 0);
			delete $edit_settings{$tag};

		} elsif ($ARGS{$tag} ne $edit_settings{$tag}) {

			if ($tag eq "banned" && (not defined $ARGS{'ban_reason'}) ) {
				$m->comp("/funclib/abort.mas",
					message => "You must supply a reason to change an account's ban status"
				);
			}

			if ($tag eq "nsda_email" && $ARGS{$tag}) {
				$ARGS{$tag} = lc($ARGS{$tag});
			}

			if ($tag eq "nsda_id" && $ARGS{$tag} == $edit->nsda) {

			} else {

				my $result = $ARGS{$tag};
				chomp $result;

				$edit->setting($tag, $result);
				$edit_settings{$tag} = $result;
			}

			if ($tag eq "ban_reason" && $ARGS{ban_reason}) {

				my $reason = $edit_settings{$tag};
				$ban_message = "Account ".$edit->email." banned by ".$person->email.". Reason: $reason";
				$ban_message = "<p style='font-weight: 600;'>".$reason."</p>";

				my $log = Tab::ChangeLog->create({
					person      => $edit->id,
					count       => $person->id,  # HACK HACK YOU ARE SUCH A HACK
					tag         => "account",
					description => $ban_message,
				});

				$subject = "Tabroom User Banned by ".$person->first." ".$person->last;

				$ban_message = "<p style='font-size: 120%;'>Account has been banned by User ID ".$person->id." ".$person->first." ".$person->last." (".$person->email."):</p>";
				$ban_message .= "<p style='font-weight: 600;'>Reason: ".$reason."</p>";
				$ban_message .= "<p style='padding-left: 1em;'>Banned ID: ".$edit->id."</p>";
				$ban_message .= "<p style='padding-left: 1em;'>Name: ".$edit->first." ".$edit->last."</p>";
				$ban_message .= "<p style='padding-left: 1em;'>Email: ".$edit->email."</p>";

				my @students = $edit->students;

				$ban_message .= "<div style='width: 100%; padding-left: 2em; border-top: 1px solid #777'>";

				if (scalar @students > 0) {

					$ban_message .= "<p style='font-size: 110%; margin-left: -1em; margin-top: 1em; font-weight: 600; color: #016F94;'> ".scalar @students." Student Records Linked:</p>";
					foreach my $student ($edit->students) {

						$ban_message .= "<p style='margin-top: 1em; font-weight: 600;'>ID: ".$student->id."</p>";
						$ban_message .= "<p style='color: #BA1D00; font-weight: 600;'>Retired</p>" if $student->retired;

						if ($student->nsda) {
							$ban_message .= "<p>NSDA ID: ".$student->nsda."</p>";
						}
						$ban_message .= "<p>Name: ".$student->first." ".$student->last."</p>";
						if ($student->chapter > 0) {
							$ban_message .= "<p>School: ".$student->chapter->id." ".$student->chapter->name."</p>";
						}
						$ban_message .= "<p>Grad Year: ".$student->grad_year."</p>";
					}
				}

				my @judges = $edit->chapter_judges;

				if (scalar @judges > 0) {
					$ban_message .= "<p style='font-size: 110%; margin-left: -1em; margin-top: 1em; font-weight: 600; color: #016F94;'> ".scalar @judges." Judge Records Linked:</p>";
					foreach my $judge (@judges) {
						$ban_message .= "<p style='margin-top: 1em; font-weight: 600;'>ID: ".$judge->id."</p>";
						$ban_message .= "<p style='color: #BA1D00; font-weight: 600;'>Retired</p>" if $judge->retired;

						$ban_message .= "<p>Name: ".$judge->first." ".$judge->last."</p>";
						if ($judge->chapter > 0) {
							$ban_message .= "<p>School: ".$judge->chapter->id." ".$judge->chapter->name."</p>";
						}
					}
				}
				$ban_message .= "</div>\n"
			}
		}
	}

	if ($ban_message) {
		my $message = $m->comp("/funclib/send_notify.mas",
			from_string => "Tabroom Userbot <littlesnitch\@www.tabroom.com>",
			ids         => [1, 25656],
			subject     => $subject,
			html        => $ban_message
		);
	}

	if ($ARGS{nsda_id} == $edit->nsda) {
		$edit->setting("nsda_id", 0);
		$msg = "NSDA ID and Learn ID were the same. Not saved";
	}

	unless ($edit_settings{'banned'}) {
		undef $ARGS{"ban_reason"};
		$edit->setting("ban_reason", 0);
	}

	$nsda =~ s/[\D_]//g;
	undef $nsda if $nsda < 1;

	my $other_user = Tab::Person->search( nsda => $nsda )->first if $nsda;

	my $err;

	if ($other_user && $other_user->id != $edit->id) {
		$err = "Changes saved, but another account (".$other_user->email.") is already linked to NSDA ID $nsda, so that was skipped";
	}

	unless ($err) {

		$edit->nsda($nsda);
		$edit->update();

		my $membership = $m->comp("/funclib/nsda/membership.mas", person => $edit, force => 1);

		my $nsda_id = eval {
			return $membership->{"person_id"};
		};

		unless ($nsda_id eq $nsda) {
			$err .= "Changes saved, but the NSDA ID $nsda does not match an NSDA record, so no link was made.";
		}
	}

    Tab::log("PROFILE CHANGE BY ADMIN: Account ID ".$edit->id." changed ($email) from IP address ".$ENV{HTTP_X_FORWARDED_FOR}." by ".$person->email) ;

	$msg = "Changes saved. ".$msg;
	$m->redirect("person_edit.mhtml?edit_id=$edit_id&msg=$msg");

</%init>
