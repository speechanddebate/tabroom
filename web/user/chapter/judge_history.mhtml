<%args>
	$dbh
	$person
	$chapter_id => undef
	$chapter_judge_id => undef
</%args>
<%init>

	my $chapter_judge = Tab::ChapterJudge->retrieve($chapter_judge_id) if $chapter_judge_id;

	unless ($chapter_judge) {
		my $msg = "You have no defined school or chapter.  Please select one at right before continuing";
		$m->redirect("/user/home.mhtml?msg=$msg");
	}

	my $chapter = $chapter_judge->chapter;

</%init>

	<div class="main">

		<h2><% $chapter->name %> Judge Roster</h2>

		<& tabbar.mas,
			chapter => $chapter,
			person  => $person,
			whoami  => "judges"
		&>

		<div class="flexrow">
			<span class="fourfifths">
				<h4><% $chapter_judge->first %> <% $chapter_judge->last %> Judging History</h4>
			</span>

			<span
				class = "fifth rightalign padright"
				id    = "<% $chapter_judge->id %>_buttonarea"
			>
			</span>
		</div>

		<& "/funclib/tablesorter.mas", table => $chapter_judge->id &>

		<table id="<% $chapter_judge->id %>">

			<thead>
				<tr>
					<th>
						Tournament
					</th>

					<th>
						Date
					</th>

					<th>
						Division
					</th>

					<th>
						Rounds
					</th>
					<th>
						Sections
					</th>
				</tr>
			</thead>

			<tbody>
<%perl>
				my $sth = $dbh->prepare("
					select
						tourn.id, tourn.start, tourn.name tourn_name,
						category.name category_name, category.abbr category_abbr,
						count(distinct panel.round) rounds,
						count(distinct panel.id) sections
					from (tourn, category, judge)

						left join ballot on ballot.judge = judge.id
						left join panel on ballot.panel = panel.id

					where 1=1
						and judge.chapter_judge = ?
						and judge.category = category.id
						and category.tourn = tourn.id
					group by judge.id
					order by tourn.end DESC
				");

				$sth->execute($chapter_judge->id);
				my $recents = $sth->fetchall_hash();

				my $section_count;
				my $round_count;
				my $tourn_count;

				foreach my $judge (@{$recents}) {

					$tourn_count++;
					$round_count += $judge->{rounds};
					$section_count += $judge->{sections};
</%perl>
					<tr>
						<td>
							<% $judge->{tourn_name} %>
						</td>

						<td
							class="centeralign"
							data-text="<% int(substr($judge->{start},0,4)) %>/<% substr($judge->{start},5,2) %>"
						>
							<% int(substr($judge->{start},5,2)) %>/<% substr($judge->{start},2,2) %>
						</td>

						<td>
							<% $judge->{category_name} %>
						</td>

						<td class="centeralign">
							<% $judge->{rounds} %>
						</td>
						<td class="centeralign">
							<% $judge->{sections} %>
						</td>
					</tr>
%				}
			</tbody>

			<tr class="yellowrow semibold">
				<td class='rightalign padright semibold'>
					Total Tournaments:
				</td>

				<td
					class="centeralign"
				>
					<% $tourn_count %>
				</td>

				<td class="rightalign">
					Rounds &amp; Sections
				</td>

				<td class="centeralign">
					<% $round_count %>
				</td>
				<td class="centeralign">
					<% $section_count %>
				</td>

			</tr>
		</table>
	</div>

	<& "judge_menu.mas",
		chapter_judge => $chapter_judge,
		chapter       => $chapter,
		person        => $person,
		whoami        => 'history',
		dbh           => $dbh
	&>
