<%args>
	$dbh
	$now
	$person
	$perms
	$student_id
</%args>
<%init>

	my $student = Tab::Student->retrieve($student_id);

	unless ($student->chapter
		&& ($perms->{"chapter"}{$student->chapter->id} || $person->site_admin)
	) {
		$m->comp('/funclib/abort.mas', message => "You do not have access to that chapter roster.");
	}

	my $sth = $dbh->prepare("
		select
			tourn.id, tourn.name, tourn.start, tourn.tz,
			event.id event_id, event.name event_name, event.abbr event_abbr, event.type event_type,
			nsda_category.name nsda_category,
			entry.id entry_id, entry.code code, entry.name entry_name,
			round.type round_type, round.name round_name, round.label round_label,
			(
				select result.place
				from result, result_set
				where 1=1
				and result.entry = entry.id
				and result.result_set = result_set.id
				and (result_set.tag = 'final' OR result_set.label = 'Final Places')
				limit 1
			) as place,
			(
				select result.place
				from result, result_set
				where 1=1
				and result.entry = entry.id
				and result.result_set = result_set.id
				and (result_set.tag = 'speaker' OR result_set.label = 'Speaker Awards')
				limit 1
			) as speaker,
			partner.id partner_id, partner.first partner_first, partner.last partner_last,
			GROUP_CONCAT(DISTINCT(CONCAT(partner.first, ' ', partner.last)) SEPARATOR ', ') partners

		from (tourn, entry, entry_student es, event, round, panel, ballot)
			left join entry_student os on os.entry = entry.id and os.student != es.student
			left join student partner on os.student = partner.id
			left join nsda_category on nsda_category.id = event.nsda_category

		where 1=1
			and es.student = ?
			and es.entry = entry.id
			and entry.event = event.id
			and event.tourn = tourn.id
			and ballot.entry = entry.id
			and ballot.panel = panel.id
			and panel.round = round.id

			and (tourn.end < NOW() OR round.published = 1)
			and tourn.hidden != 1

		group by entry.id
		order by tourn.start DESC, round.name DESC
	");

	$sth->execute($student->id);

	my $results = $sth->fetchall_hash();

</%init>

	<& "/funclib/tablesorter.mas", table => $student->id."_record" &>

	<div class="main">

		<div class="flexrow">
			<span class="threequarters">
				<h4><% $student->first %> <% $student->last %> Competitive History</h4>
			</span>
			<span
				class="quarter rightalign nospace"
				id="<% $student->id %>_record_buttonarea"
			>
			</span>
		</div>

		<table id="<% $student->id %>_record">

			<thead>
				<tr>
					<th>
						Tournament
					</th>
					<th>
						Date
					</th>
					<th class='hiddencsv'>
						Event Name
					</th>
					<th>
						Event
					</th>
					<th class='hiddencsv'>
						Event Category
					</th>
					<th>
						Partners
					</th>
					<th>
						Last Round
					</th>

					<th class="hiddencsv">
						Round Type
					</th>

					<th>
						Speaker
					</th>
					<th>
						Result
					</th>
				</tr>
			</thead>

			<tbody>
%				foreach my $result (@{$results}) {

					<tr>
						<td>
							<% $result->{name} %>
						</td>

						<td class="rightalign" data-text="<% $result->{start} %>">
							<& "/funclib/showdate.mas",
								string => $result->{start},
								tz     => $result->{tz},
								format => "medium"
							&>
						</td>

						<td class="hiddencsv">
							<% $result->{event_name} %>
						</td>

						<td class="hiddencsv">
							<% $result->{nsda_category} %>
						</td>

						<td class="centeralign">
							<% $result->{event_abbr} %>
						</td>

						<td>
							<% $result->{partners} %>
						</td>

						<td>
							<% $result->{round_label} || "Rd ".$result->{round_name} %>
						</td>

						<td class="hiddencsv">
							(<% $result->{round_type} %>)
						</td>

						<td class='centeralign'>
							<% $result->{speaker} %>
						</td>

						<td class='centeralign'>
							<% $result->{place} %>
						</td>
					</tr>
%				}
			</tbody>
		</table>

	</div>

	<& "student_menu.mas",
		student => $student,
	&>

