<%args>
	$dbh
	$search => undef
	$caller => undef
</%args>
<%init>

	$search =~ s/\&/and/g;
	$search =~ s/\//or/g;
	$search =~ s/\\/-/g;
	$search =~ tr/\$%&~_^{}/ /;

	unless ($search) {
		my $err = "No search term entered";
		$m->redirect("/index/index.mthml?err=$err");
	}

#	return if $m->cache_self( key => $search, expires_in => '1h' );

	my $sth = $dbh->prepare("
		select
		tourn.id, tourn.name, tourn.city, tourn.state, tourn.country, tourn.webname,
			GROUP_CONCAT(distinct circuit.abbr SEPARATOR '# '),
			GROUP_CONCAT(distinct event.name SEPARATOR '# '),
			CONVERT_TZ(tourn.start, '+00:00', tourn.tz),
			CONVERT_TZ(tourn.end, '+00:00', tourn.tz)

		from tourn
			left join tourn_circuit tc on tc.tourn = tourn.id
			left join circuit on circuit.id = tc.circuit
			left join event on event.tourn = tourn.id and event.type != 'attendee'

		where tourn.name like ?
			and tourn.hidden = 0

		group by tourn.id
		order by tourn.start DESC, tourn.name, event.type, event.name
		limit 150
	");

	$sth->execute("%".$search."%");

</%init>

	<div class="menu">

		<div class="sidenote">

			<h4>Search results</h4>

			<p>
				This results is showing the 50 search matches for "<% $search %>",
				sorted in reverse order by date.  If you cannot find the
				tournament you're looking for, try a more specific search.
			</p>

		</div>

	</div>

	<div class="main">

		<& "/funclib/tablesorter.mas", table => "search_results" &>

		<span class="fourfifths nospace">
			<h4>Tournaments matching "<% $search %>":</h4>
		</span>

		<span
			class = "fifth nospace rightalign"
			id    = "search_results_buttonarea"
		></span>

		<table id="search_results">

			<thead>
				<tr class="yellowrow smallish">
					<th class="limit3">
						Tournament Name
					</th>

					<th>
						Location
					</th>

					<th>
						Date
					</th>

					<th>
						Events
					</th>

					<th class="limitsmall">
						Circuits
					</th>
				</tr>
			</thead>
			<tbody>
<%perl>
			while (
				my (
					$id, $name, $city, $state, $country, $web, $circuits, $events, $start, $end
				) = $sth->fetchrow_array()
			) {

				my @circuits = split(/\#/, $circuits);
				my @events = split(/\#/, $events);

				my $circ_string;
				my $event_string;

				foreach my $circ (sort {$a cmp $b} @circuits) {
					$circ_string .= "<span class='full centeralign padvertless padleft padright nowrap'>$circ</span>";
				}
				foreach my $event (sort {$a cmp $b} @events) {
					$event_string .= "<span title=".$event." class='padleft padright half smaller nospace padvertless nowrap'>$event</span>";
				}

				$state = substr($state, 0, 2);
</%perl>
				<tr class="small">

					<td class="nospace">
						<a
							class = "bluetext semibold full padvertless link-underline hover padleft"
							href  = "/index/tourn/index.mhtml?tourn_id=<% $id %>"
							target= "_blank"
						>
							<% $name %>
						</a>
					</td>

					<td class="limitsmall">
						<% $city ? $city : "" %><% $city eq "Online" ? "" : ", "%>

%						unless ($city eq "Online") {
							<%
								$state ? $state : ""
							%><%
								$country && $country ne "US" && $state ? "/" : ""
							%><%
								$country && $country ne "US" ? $country : ""
							%>
%						}
					</td>

					<td data-text="<% $start %>" class="nowrap limitsmall">
						<& "/funclib/showrange.mas",
							start_string => $start,
							end_string   => $end,
							format       => 'murica_fixed',
							year         => 1,
						&>
					</td>

					<td class="nospace">
						<div class='full flexrow wrap'>
							<% $event_string %>
						</div>
					</td>

					<td class="nospace">
						<div class='full flexrow wrap'>
							<% $circ_string %>
						</div>
					</td>
				</tr>
%			}
			</tbody>
		</table>

	</div>

