<%args>
	$round_id => undef
	$person => undef
</%args>
<%init>

	my $key = $round_id;

    if ($ARGS{"invalidate"}) {
        $m->cache(expire => $key);
    } else {
        return if $m->cache_self(
            key        => $key,
            expires_in => '5m',
        );
    }

	$m->abort unless $round_id;

	my $round = Tab::Round->retrieve($round_id);

	unless ($round) {
		$m->print("No round entered, try again");
		$m->abort;
	}

	my $event = $round->event;
	my $tourn = $event->tourn if $round;

	my $schem = $event->setting("schem_designation");
	$schem = "codes" unless $schem;

	unless (
		$round->published == 3
		|| ($person && $person->site_admin)
	) {

		$m->print("<div class='main'>");
		$m->print("<p class='err'>This round's clearing list  has not been published.</p>");
		$m->print("</div>");
		$m->abort;
	}

	my $start = $round->start_time;
	$start = $round->timeslot->start unless $start;

</%init>

	<& menu.mas,
		tourn_id => $tourn->id,
		event_id => $event->id,
		round_id => $round_id &>

	<div class="main">

		<& /index/tourn/title.mas,
			tourn => $tourn
		&>

        <& /index/tourn/tabbar.mas,
			tourn  => $tourn,
			person => $person
		&>

		<div class="full flexrow padtop">

			<span class="threefifths">
				<h5 class="nospace">
					<% $event->name %>
				</h5>
			</span>

			<span class="twofifths nospace">
				<h5 class="rightalign semibold">
					Round Starts: <& "/funclib/showtime.mas",
						dt     => $start,
						tz     => $tourn->tz,
						format => 'formalday',
						tzname => 'yeppers'
					&>
				</h5>
			</span>
		</div>

		<div class="centeralign padvert blueborderbottom marbottomless">
			<h3>
				Advancing to <% $round->label || "Round ".$round->name %>
			</h3>
		</div>

%		if ($round->setting("notes")) {
			<div class="row centeralign padvertmore redtext semibold marbottommore">
				<% $round->setting("notes") %>
			</div>
<%perl>
		}

		my @entries = $m->comp("/funclib/round_entries.mas", round => $round);
		my $switch;

		my %panel_count;

		foreach my $entry (@entries) {
			$panel_count{$entry->panelid}++;
		}

		foreach my $entry (@entries) {
			$entry->panelbye("") if $panel_count{$entry->panelid} > 1;
		}

</%perl>

		<div class="flexrow odd semibold padvertless">

<%perl>
 		foreach my $entry (
			sort {
				$a->panelbye <=> $b->panelbye
				|| $a->code cmp $b->code
			}
			@entries
		) {
			if ($switch++ > 1) {
</%perl>
				</div>
				<div class="flexrow odd semibold">
%				$switch = 1;
%			}
			<span class="half flexrow ltborderleft centeralign">
				<span class="threequarters padleft padvertless">
					<% $schem eq "names" ? $entry->name : "" %>
					<% $schem eq "codes" ? $entry->code : "" %>
					<% $schem eq "both" ? $entry->code." ".$entry->name : "" %>
				</span>
				<span class="quarter rightalign padrightmore italic">
					<% $entry->panelbye ? "(Bye)" : "" %>
				</span>
			</span>
%		}
		</div>
	</div>
