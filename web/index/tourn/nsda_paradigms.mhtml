<%args>
	$dbh
	$category_id => undef
	$jpool_id    => undef
	$person      => undef
</%args>
<%init>

	$category_id =~ s/[\D_]//g;
	my $key = $category_id;

#	return if $m->cache_self(
#		key        => $key,
#		expires_in => '120m'
#	);

	my $category = Tab::Category->retrieve($category_id);
	unless ($category && $category->id) {
		$m->comp("/funclib/abort.mas",
			message => "No such category"
		);
	}

	my %category_settings = $category->all_settings();

	unless ($category_settings{publish_paradigms} && $category_settings{paradigm_quiz}) {
		$m->comp("/funclib/abort.mas",
			message => "Category paradigms are not published"
		);
	}

	my $sth = $dbh->prepare("
		select
			judge.id, judge.first, judge.middle, judge.last,
			school.name school_name, chapter.state state, chapter.country country,
			person.state person_state, person.country person_country,
			pq.id pq
		from (judge)
			left join school on judge.school = school.id
			left join chapter on school.chapter = chapter.id
			left join person on person.id = judge.person
			left join person_quiz pq on pq.person = judge.person and pq.quiz = ?
		where 1=1
			and judge.category = ?
		order by judge.last
	");

	$sth->execute($category_settings{paradigm_quiz}, $category->id);

	my $judges = $sth->fetchall_hash();

	my $tourn = $category->tourn;

</%init>

	<div class="main">

		<& "title.mas", tourn => $tourn &>

        <& "tabbar.mas",
			tourn  => $tourn,
			person => $person,
			whoami => "judges"
		&>

		<span class="threequarters nospace">
			<h4><% $category->name %> Paradigms</h4>
		</span>

		<span
			class = "quarter rightalign nospace"
			id    = "<% $category->id %>_buttonarea"
		> </span>

		<& "/funclib/tablesorter.mas",
			table => $category->id
		&>

		<table id="<% $category->id %>">
			<thead>
				<tr class="yellowrow smallish">
					<th>
						Paradigm
					</th>

					<th>
						Judge
					</th>

					<th>
						School
					</th>

					<th>
						State
					</th>
				</tr>
			</thead>

			<tbody>

%				foreach my $judge (@{$judges}) {

					<tr>
						<td class="centeralign nospace">
%							if ($judge->{pq}) {
								<a
									class       ="full white"
									href        ="paradigm.mhtml?tourn_id=<% $tourn %>&judge_id=<% $judge->{id} %>"
								><span class ="buttonwhite bluetext fa fa-sm fa-file-text-o"></span></a>
%							}
						</td>

						<td data-text="<% $judge->{last} %>">
							<% $judge->{first} %>
							<% $judge->{middle} %>
							<% $judge->{last} %>
						</td>

						<td>
							<% $judge->{school_name} || "Unaffiliated" %>
						</td>

						<td class="centeralign">
							<% $judge->{state} || $judge->{country} || $judge->{person_state} || $judge->{person_country} %>
						</td>
					</tr>
%				}

			</tbody>
		</table>
	</div>

	<& "menu.mas",
		category_id => int($category_id),
		jpool_id    => int($jpool_id),
		whoami      => "paradigm",
		tourn       => $tourn
	&>

