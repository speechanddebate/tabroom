#!/bin/bash

hostname=`hostname -s`
user="root";

if [[ "$1" != "" ]]; then
    database="$1"
else
	database="tabroom"
	tmp_database="tabroom"
fi

# never run this on a production server, even on purpose.
# why yes, I am too lazy to look up how arrays work in bash

prodserver='tabroom-db'
prodserver1='tabroom-replica'

echo "Loading latest database backup into ${database}"
echo "Start time is"
date

if [[ ${hostname} != ${prodserver} ]]; then
if [[ ${hostname} != ${prodserver1} ]]; then

	rm /tmp/tabroom.sql

	if [[ ${hostname} == "amun" ]]; then
		echo "Copying the latest database backup"
		cp /net/backups/database-hourlies/latest/tabroom.sql.bz2 /tmp/tabroom.sql.bz2
	else
		echo "Downloading latest database backup"
		aws s3 cp s3://nsda-backups/00-latest/tabroom.sql.bz2  /tmp/tabroom.sql.bz2
	fi

	echo "Decompressing backup data"
	pbzip2 -d /tmp/tabroom.sql.bz2

	echo "Deleting old tabroom database"
	mariadb-admin -u ${user} -f drop ${tmp_database}

	echo "Creating new blank tabroom database"
	mariadb-admin -u ${user} create ${tmp_database}

	echo "Loading datafile into new database"
	pv /tmp/tabroom.sql | mariadb -u ${user} -f ${tmp_database}

	echo "Removing data dump"
	rm /tmp/tabroom.sql

	echo "Running database table analysis for version mismatch"
	pv /www/tabroom/doc/sql/fix-10to11.sql | mariadb -u ${user} -f ${tmp_database}

#	echo "Moving the database from ${tmp_database} to ${database}"
#	mariadb-dump ${tmp_database} --no-data --routines --triggers --events > /tmp/rte.sql

#	mariadb -ss -e"SELECT CONCAT('RENAME TABLE ${tmp_database}.', TABLE_NAME, ' TO ${database}.', TABLE_NAME, ';') FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA = '${tmp_database}'" > /tmp/rename_table.sql

#	mariadb-admin -u ${user} -f drop ${database}
#	mariadb-admin -u ${user} -f create ${database}

#	pv /tmp/rename_table.sql | mariadb -u ${user} -f ${tmp_database}
#	pv /tmp/rte.sql | mariadb -u ${user} -f ${tmp_database}

#	rm /tmp/rte.sql
#	rm /rename_table.sql
#	mariadb-admin -u ${user} -f drop ${tmp_database}

	echo "All set!"
	echo "Ended at"
	date
fi
fi
